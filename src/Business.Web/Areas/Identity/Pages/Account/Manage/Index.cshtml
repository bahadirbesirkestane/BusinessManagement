@page
@model Business.Web.Areas.Identity.Pages.Account.Manage.IndexModel
@using Business.Infrastructure.Identity
@{
    ViewData["Title"] = "Hesap Yönetimi";
    var returnUrl = $"{Request.Path}{Request.QueryString}";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Identity Hesap Yönetimi</p>
            <h2>Hesap Yönetimi</h2>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info">@Model.StatusMessage</div>
    }

    <div class="table-responsive">
        <table class="table app-table align-middle">
            <tbody>
                <tr>
                    <th>E-posta</th>
                    <td>@Model.Email</td>
                    <td><span class="status-pill @(Model.EmailConfirmed ? "status-success" : "status-danger")">@(Model.EmailConfirmed ? "Doğrulandı" : "Doğrulanmadı")</span></td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-page="./Email">E-posta Yönet</a></td>
                </tr>
                <tr>
                    <th>Şifre</th>
                    <td>Hesap şifrenizi değiştirebilirsiniz.</td>
                    <td></td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-page="./ChangePassword">Şifre Değiştir</a></td>
                </tr>
                <tr>
                    <th>2FA</th>
                    <td>@(Model.IsAdmin ? "Admin iki aşamalı doğrulama ayarı" : "Çalışanlar için zorunlu değil")</td>
                    <td><span class="status-pill @(Model.TwoFactorEnabled ? "status-success" : "status-danger")">@(Model.TwoFactorEnabled ? "Açık" : "Kapalı")</span></td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-page="./TwoFactorAuthentication">2FA Yönet</a></td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<section class="panel-block mt-3">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">İletişim ve Bildirim</p>
            <h2>Telefon ve Telegram</h2>
        </div>
    </div>

    <form method="post" asp-page-handler="SaveProfile" class="app-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div class="mb-3">
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="+90 5xx xxx xx xx" />
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                <small class="text-muted">Telefon alanı kullanıcı kartında saklanır. Telegram eşleştirmesi için zorunlu değildir ama iletişim kaydı için faydalıdır.</small>
            </div>
            <div class="mb-3">
                <label class="check-card check-inline">
                    <input asp-for="Input.TelegramNotificationsEnabled" />
                    <span>Telegram bildirimlerini aktif tut</span>
                </label>
                <small class="text-muted d-block mt-2">Görev bildirimleri yalnızca Telegram hesabın bağlandıktan sonra gönderilir.</small>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">İletişim Ayarlarını Kaydet</button>
        </div>
    </form>
</section>

<section class="panel-block mt-3">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Telegram</p>
            <h2>Hesap Bağlama</h2>
        </div>
    </div>

    @if (!Model.TelegramSettingsEnabled || string.IsNullOrWhiteSpace(Model.TelegramBotUserName))
    {
        <p class="empty-note">Telegram bağlama sistemi şu anda hazır değil. Lütfen sistem yöneticinizle görüşün.</p>
    }
    else
    {
        <div class="list-stack">
            <div class="list-row">
                <span>
                    <strong>Bağlı hesap durumu</strong>
                    <small>
                        @if (!string.IsNullOrWhiteSpace(Model.TelegramChatId))
                        {
                            <text>Telegram hesabın bağlı.</text>
                        }
                        else
                        {
                            <text>Henüz Telegram hesabı bağlanmadı.</text>
                        }
                    </small>
                </span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.TelegramUsername))
            {
                <div class="list-row">
                    <span><strong>Kullanıcı adı</strong><small>@($"@{Model.TelegramUsername}")</small></span>
                </div>
            }

            @if (Model.TelegramLinkedAt.HasValue)
            {
                <div class="list-row">
                    <span><strong>Bağlanma tarihi</strong><small>@Model.TelegramLinkedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small></span>
                </div>
            }
        </div>

        <div class="mt-3">
            <p class="mb-2">Telegram hesabını bağlamak için:</p>
            <ol>
                <li><strong>@($"@{Model.TelegramBotUserName}")</strong> botunu Telegram'da aç.</li>
                <li>Aşağıdaki bağlama kodunu üret.</li>
                <li>Üretilen kodu bota mesaj olarak gönder.</li>
            </ol>
        </div>

        <form method="post" asp-page-handler="GenerateTelegramLink" class="mt-3">
            <button type="submit" class="btn btn-outline-primary">Telegram Bağlama Kodu Üret</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.ActiveTelegramLinkCode) && Model.ActiveTelegramLinkExpiresAt.HasValue)
        {
            <div class="alert alert-secondary mt-3">
                <strong>Aktif bağlama kodu:</strong> <code>@Model.ActiveTelegramLinkCode</code><br />
                <small>Son geçerlilik: @Model.ActiveTelegramLinkExpiresAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
            </div>
        }
    }
</section>

<section class="panel-block mt-3">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Görünüm</p>
            <h2>Tema Tercihi</h2>
        </div>
    </div>

    <form asp-controller="Theme" asp-action="Update" method="post" class="theme-settings-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <div class="theme-option-grid">
            @foreach (var option in AppThemes.Options)
            {
                var isSelected = Model.CurrentTheme == option.Key;
                var description = option.Key switch
                {
                    AppThemes.Current => "Mevcut beyaz temayı olduğu gibi korur.",
                    AppThemes.Soft => "Kırık beyaz yüzeylerle daha yumuşak ve sıcak bir görünüm sunar.",
                    AppThemes.Dark => "Dengeli koyu yüzeyler kullanır.",
                    _ => string.Empty
                };
                <label class="theme-option-card @(isSelected ? "is-selected" : null)">
                    <input type="radio" name="theme" value="@option.Key" checked="@isSelected" />
                    <span class="theme-option-preview theme-preview-@option.Key" aria-hidden="true"></span>
                    <strong>@option.Value</strong>
                    <small>@description</small>
                </label>
            }
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Tema Tercihini Kaydet</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
