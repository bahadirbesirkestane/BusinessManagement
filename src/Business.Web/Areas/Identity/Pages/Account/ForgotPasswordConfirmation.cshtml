@page
@model Business.Web.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Şifre Sıfırlama";
}

<section class="panel-block form-panel auth-recovery-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Hesap Güvenliği</p>
            <h2>Talebiniz alındı</h2>
        </div>
    </div>

    <div class="empty-state">
        E-posta adresi sistemde kayıtlı ve doğrulanmışsa şifre sıfırlama bağlantısı gönderilecektir.
    </div>
    <div class="form-actions">
        <a class="btn btn-primary" asp-page="/Account/Login" asp-area="Identity">Girişe Dön</a>
    </div>
</section>
