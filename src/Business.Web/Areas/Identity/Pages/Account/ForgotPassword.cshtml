@page
@model Business.Web.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<section class="panel-block form-panel auth-recovery-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Hesap Güvenliği</p>
            <h2>Şifremi Unuttum</h2>
        </div>
    </div>

    <form method="post" class="app-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div class="mb-3 wide">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-page="/Account/Login" asp-area="Identity">Girişe Dön</a>
            <button class="btn btn-primary" type="submit">Sıfırlama Linki Gönder</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
