@page
@model Business.Web.Areas.Identity.Pages.Account.RecoveryCodeLoginModel
@{
    ViewData["Title"] = "Kurtarma Kodu";
}

<section class="panel-block form-panel auth-recovery-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Hesap Güvenliği</p>
            <h2>Kurtarma kodu ile giriş</h2>
        </div>
    </div>

    <form method="post" class="app-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div class="mb-3 wide">
                <label asp-for="Input.RecoveryCode" class="form-label"></label>
                <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="one-time-code" />
                <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
            </div>
        </div>
        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-page="./TwoFactorLogin" asp-route-returnUrl="@Model.ReturnUrl">Authenticator Koduna Dön</a>
            <button class="btn btn-primary" type="submit">Giriş Yap</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
