@page
@model Business.Web.Areas.Identity.Pages.Account.AcceptInvitationModel
@{
    ViewData["Title"] = "Davet Kabul";
}

<section class="panel-block form-panel auth-recovery-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Kullanıcı Daveti</p>
            <h2>Hesabınızı doğrulayın</h2>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-page="/Account/Login" asp-area="Identity">Girişe Dön</a>
        </div>
    }
    else
    {
        <form method="post" class="app-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Input.UserId" />
            <input type="hidden" asp-for="Input.EmailToken" />
            <input type="hidden" asp-for="Input.PasswordToken" />

            <div class="form-grid">
                <div class="mb-3">
                    <label asp-for="Input.FullName" class="form-label">Ad Soyad</label>
                    <input asp-for="Input.FullName" class="form-control" disabled />
                </div>
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">E-posta</label>
                    <input asp-for="Input.Email" class="form-control" disabled />
                </div>
                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label"></label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" type="submit">Hesabı Aktifleştir</button>
            </div>
        </form>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
