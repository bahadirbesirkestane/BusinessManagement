@model IReadOnlyList<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Roller";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Kullanıcılar ve Yetkiler</p>
            <h2>Roller</h2>
        </div>
        <a class="btn btn-primary" asp-action="Create">Rol Ekle</a>
    </div>
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-warning">@error</div>
    }
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead><tr><th>Rol</th><th></th></tr></thead>
            <tbody>
            @foreach (var role in Model)
            {
                <tr>
                    <td><strong>@role.Name</strong></td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@role.Id">Yetkileri Düzenle</a>
                        <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="inline-form">
                            <button class="btn btn-sm btn-outline-danger" type="submit">Sil</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
