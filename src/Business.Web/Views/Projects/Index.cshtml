@model IReadOnlyList<Business.Domain.Entities.Project>
@{
    ViewData["Title"] = "Projeler";
    var canCreateProject = User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsCreate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canUpdateProject = User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsUpdate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canChangeProjectStatus = User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsChangeStatus) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canDeleteProject = User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsDelete) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canUseBulkActions = canUpdateProject || canChangeProjectStatus || canDeleteProject;
    var isDeferredLoad = ViewBag.IsDeferredLoad == true;
    var hasMore = ViewBag.HasMore == true;
    var listAction = (string)(ViewBag.ListAction ?? "Index");
    var isArchiveList = ViewBag.IsArchiveList == true;
    var requiresManualLoad = isDeferredLoad;
    var currentTake = (int)(ViewBag.CurrentTake ?? 50);
    var nextTake = (int)(ViewBag.NextTake ?? (currentTake + 50));
    var showAll = ViewBag.ShowAll == true;
    var statusOptions = (IReadOnlyList<ProjectStatus>)(ViewBag.StatusOptions ?? Enum.GetValues<ProjectStatus>().ToList());
    var moreRoute = new Dictionary<string, string?>();
    var showAllRoute = new Dictionary<string, string?>();
    moreRoute["q"] = ViewBag.FilterQ;
    moreRoute["status"] = ViewBag.FilterStatus?.ToString();
    moreRoute["priority"] = ViewBag.FilterPriority?.ToString();
    moreRoute["customerId"] = ViewBag.FilterCustomerId?.ToString();
    moreRoute["sort"] = ViewBag.Sort;
    if (requiresManualLoad)
    {
        moreRoute["load"] = "true";
        showAllRoute["load"] = "true";
    }
    moreRoute["take"] = nextTake.ToString();
    showAllRoute["q"] = ViewBag.FilterQ;
    showAllRoute["status"] = ViewBag.FilterStatus?.ToString();
    showAllRoute["priority"] = ViewBag.FilterPriority?.ToString();
    showAllRoute["customerId"] = ViewBag.FilterCustomerId?.ToString();
    showAllRoute["sort"] = ViewBag.Sort;
    showAllRoute["showAll"] = "true";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Proje merkezi</p>
            <h2>@(ViewBag.ProjectListTitle ?? "Tüm projeler")</h2>
            <p class="record-count">
                @(isDeferredLoad ? "Liste henüz yüklenmedi." : $"Gösterilen kayıt sayısı: {Model.Count}")
            </p>
        </div>
        <div class="toolbar-actions">
            @if (isArchiveList)
            {
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Aktif liste</a>
                <a class="btn btn-outline-primary btn-sm" asp-action="DownloadArchive">Arşivi indir</a>
            }
            else
            {
                <a class="btn btn-outline-secondary btn-sm" asp-action="Archived">Arşiv</a>
            }
            @if (canCreateProject)
            {
                <a class="btn btn-primary btn-sm" asp-action="Create">Yeni proje</a>
            }
        </div>
    </div>

    <form id="projectsFilterForm" asp-action="@listAction" method="get" class="list-filter-bar">
        @if (requiresManualLoad)
        {
            <input type="hidden" name="load" value="true" />
        }
        <input type="hidden" name="take" value="@currentTake" />
        <div class="filter-field filter-search">
            <span class="filter-icon" aria-hidden="true">⌕</span>
            <input name="q" value="@ViewBag.FilterQ" class="form-control form-control-sm" placeholder="Kod, proje veya müşteri ara" />
        </div>
        <select name="status" class="form-select form-select-sm">
            <option value="">Durum</option>
            @foreach (var item in statusOptions)
            {
                <option value="@item" selected="@(ViewBag.FilterStatus == item)">@item.ToDisplayName()</option>
            }
        </select>
        <select name="priority" class="form-select form-select-sm">
            <option value="">Öncelik</option>
            @foreach (ProjectPriority item in Enum.GetValues<ProjectPriority>())
            {
                <option value="@item" selected="@(ViewBag.FilterPriority == item)">@item.ToDisplayName()</option>
            }
        </select>
        <select name="customerId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Müşteri ara veya seç">
            <option value="">Müşteri</option>
            @foreach (var customer in ViewBag.Customers)
            {
                <option value="@customer.Id" selected="@(ViewBag.FilterCustomerId == customer.Id)">@customer.Name</option>
            }
        </select>
        <select name="sort" class="form-select form-select-sm">
            <option value="">Sırala: Yeni</option>
            <option value="code" selected="@(ViewBag.Sort == "code")">Kod</option>
            <option value="name" selected="@(ViewBag.Sort == "name")">Proje adı</option>
            <option value="target" selected="@(ViewBag.Sort == "target")">Hedef tarih</option>
            <option value="status" selected="@(ViewBag.Sort == "status")">Durum</option>
            <option value="created" selected="@(ViewBag.Sort == "created")">Eski kayıt</option>
        </select>
        <button class="icon-filter-button" type="submit" title="Filtrele" aria-label="Filtrele">⌕</button>
        <a class="icon-filter-button clear" asp-action="@listAction" title="Temizle" aria-label="Temizle">×</a>
    </form>

    @if (canUseBulkActions)
    {
        <form id="bulkActionForm" method="post" class="bulk-action-bar smart-bulk-bar" data-bulk-panel="bulkActionForm" hidden>
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <span class="bulk-selection-count" data-bulk-count="bulkActionForm">0 kayıt seçildi</span>
            <div class="bulk-bar-actions">
                <button class="btn btn-outline-secondary btn-sm" type="button" data-bulk-clear="bulkActionForm">Seçimi temizle</button>
                @if (canUpdateProject)
                {
                    <button class="btn btn-outline-primary btn-sm" type="submit" formaction="@Url.Action("BulkArchive")" name="archived" value="@(isArchiveList ? "false" : "true")">
                        @(isArchiveList ? "Seçilenleri aktife al" : "Seçilenleri arşivle")
                    </button>
                }
                @if (canChangeProjectStatus)
                {
                    <select class="form-select form-select-sm" name="status" aria-label="Toplu proje durumu">
                        @foreach (ProjectStatus status in Enum.GetValues<ProjectStatus>())
                        {
                            <option value="@status">@status.ToDisplayName()</option>
                        }
                    </select>
                    <button class="btn btn-outline-secondary btn-sm" type="submit" formaction="@Url.Action("BulkUpdateStatus")">Durumu uygula</button>
                }
                @if (canDeleteProject)
                {
                    <button class="btn btn-outline-danger btn-sm" type="submit" formaction="@Url.Action("BulkDelete")" data-bulk-submit="bulkActionForm">Seçilenleri sil</button>
                }
            </div>
        </form>
    }

    @if (isDeferredLoad)
    {
        <div class="empty-note empty-note-empty-state">
            <div>
                <strong>Veriler hazır bekliyor.</strong>
                <span>Yanlışlıkla ağır liste açılmasını önlemek için proje kayıtları otomatik yüklenmez. Filtrelerinizi seçip verileri getirin.</span>
            </div>
            <div class="empty-state-actions">
                <button class="btn btn-primary btn-sm" type="submit" form="projectsFilterForm">Verileri getir</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="@listAction" asp-all-route-data="showAllRoute">Tümünü göster</a>
            </div>
        </div>
    }
    else if (!Model.Any())
    {
        <div class="empty-note empty-note-empty-state">
            <div>
                <strong>Uygun proje bulunamadı.</strong>
                <span>@(isArchiveList ? "Arşivde gösterilecek proje yok." : "Filtreleri temizleyin ya da tamamlanan projeler için ayrı sayfayı açın.")</span>
            </div>
            @if (canCreateProject)
            {
                <a class="btn btn-primary btn-sm" asp-action="Create">Yeni proje oluştur</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive table-responsive-menu">
            <table class="table app-table align-middle">
                <thead>
                    <tr>
                        @if (canUseBulkActions)
                        {
                            <th class="bulk-check-cell">
                                <input type="checkbox" data-bulk-toggle="bulkActionForm" aria-label="Tüm projeleri seç" />
                            </th>
                        }
                        <th>Kod</th>
                        <th>Proje</th>
                        <th>Müşteri</th>
                        <th>Durum</th>
                        <th>Hedef</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var project in Model)
                    {
                        var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
                        var previewDescription = !string.IsNullOrWhiteSpace(project.Description)
                            ? project.Description
                            : "Bu proje için açıklama girilmemiş. Detay sayfasından görev, sipariş ve güncellemeleri inceleyebilirsiniz.";
                        <tr class="status-row status-@project.Status.ToString().ToLowerInvariant()"
                            data-row-link="@Url.Action("Details", new { id = project.Id, returnUrl })"
                            data-preview-group="projects-list"
                            data-preview-title="@project.Code - @project.Name"
                            data-preview-subtitle="Müşteri: @(project.Customer?.Name ?? project.CustomerName ?? "Belirtilmedi")"
                            data-preview-meta="Hedef tarih: @(project.TargetEndDate?.ToString("dd.MM.yyyy") ?? "Planlanmadı")"
                            data-preview-description="@previewDescription"
                            data-preview-status="@project.Status.ToDisplayName()">
                            @if (canUseBulkActions)
                            {
                                <td><input type="checkbox" name="ids" value="@project.Id" form="bulkActionForm" /></td>
                            }
                            <td><strong>@project.Code</strong></td>
                            <td>@project.Name</td>
                            <td>@(project.Customer?.Name ?? project.CustomerName ?? "-")</td>
                            <td>
                                @if (canChangeProjectStatus && !isArchiveList)
                                {
                                    <form asp-action="UpdateStatus" method="post" class="inline-status-form">
                                        <input type="hidden" name="id" value="@project.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <select name="status" class="status-select status-@project.Status.ToString().ToLowerInvariant()" onchange="this.form.submit()" aria-label="Proje durumu">
                                            @foreach (ProjectStatus status in Enum.GetValues<ProjectStatus>())
                                            {
                                                <option value="@status" selected="@(project.Status == status)">@status.ToDisplayName()</option>
                                            }
                                        </select>
                                    </form>
                                }
                                else
                                {
                                    <span class="status-pill status-@project.Status.ToString().ToLowerInvariant()">@project.Status.ToDisplayName()</span>
                                }
                            </td>
                            <td>@(project.TargetEndDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td class="text-end action-cell">
                                <div class="action-shell">
                                    <button class="preview-trigger" type="button" data-preview-trigger title="Hızlı önizleme" aria-label="Hızlı önizleme">i</button>
                                    <details class="action-menu">
                                        <summary aria-label="Proje işlemleri">...</summary>
                                        <div class="action-menu-list">
                                            <a asp-action="Details" asp-route-id="@project.Id" asp-route-returnUrl="@returnUrl">Detay</a>
                                            @if (canUpdateProject)
                                            {
                                                <a asp-action="Edit" asp-route-id="@project.Id">Düzenle</a>
                                                <form asp-action="Archive" asp-route-id="@project.Id" method="post" class="inline-form">
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <input type="hidden" name="archived" value="@(isArchiveList ? "false" : "true")" />
                                                    <button class="link-button" type="submit">@(isArchiveList ? "Aktife al" : "Arşivle")</button>
                                                </form>
                                            }
                                            @if (canDeleteProject)
                                            {
                                                <a class="text-danger" asp-action="Delete" asp-route-id="@project.Id">Sil</a>
                                            }
                                        </div>
                                    </details>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (hasMore || showAll)
        {
            <div class="list-load-more">
                @if (hasMore)
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-action="@listAction" asp-all-route-data="moreRoute">Daha fazla göster</a>
                }
                @if (!showAll)
                {
                    <a class="btn btn-outline-primary btn-sm" asp-action="@listAction" asp-all-route-data="showAllRoute">Tümünü göster</a>
                }
            </div>
        }
    }
</section>

<div class="compact-preview-popover" data-compact-preview hidden>
    <span class="list-preview-status" data-preview-status></span>
    <h3 data-preview-title></h3>
    <p class="list-preview-subtitle" data-preview-subtitle></p>
    <p class="list-preview-meta" data-preview-meta></p>
    <p class="list-preview-description" data-preview-description></p>
</div>
