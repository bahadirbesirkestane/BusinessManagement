@model IReadOnlyList<Project>
@{
    ViewData["Title"] = "Proje Takvimi";
    var monthStart = (DateTime)ViewBag.MonthStart;
    var previousMonth = (DateTime)ViewBag.PreviousMonth;
    var nextMonth = (DateTime)ViewBag.NextMonth;
    var today = (DateTime)ViewBag.Today;
    var firstGridDay = monthStart.AddDays(-(((int)monthStart.DayOfWeek + 6) % 7));
    var monthTitle = monthStart.ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"));
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Projeler</p>
            <h2>Proje takvimi</h2>
        </div>
        <div class="calendar-toolbar">
            <a class="btn btn-outline-secondary btn-sm" asp-action="Calendar" asp-route-year="@previousMonth.Year" asp-route-month="@previousMonth.Month">Önceki</a>
            <strong>@monthTitle</strong>
            <a class="btn btn-outline-secondary btn-sm" asp-action="Calendar" asp-route-year="@nextMonth.Year" asp-route-month="@nextMonth.Month">Sonraki</a>
            <a class="btn btn-outline-primary btn-sm" asp-action="Index">Tüm Projeler</a>
        </div>
    </div>

    <div class="project-calendar">
        @foreach (var dayName in new[] { "Pzt", "Sal", "Çar", "Per", "Cum", "Cmt", "Paz" })
        {
            <div class="calendar-weekday">@dayName</div>
        }

        @for (var i = 0; i < 42; i++)
        {
            var day = firstGridDay.AddDays(i);
            var isOutsideMonth = day.Month != monthStart.Month;
            var isToday = day.Date == today.Date;
            var dayProjects = Model
                .Where(project =>
                    (project.StartDate.HasValue && project.StartDate.Value.Date == day.Date) ||
                    (project.TargetEndDate.HasValue && project.TargetEndDate.Value.Date == day.Date) ||
                    (project.StartDate.HasValue && project.TargetEndDate.HasValue && project.StartDate.Value.Date < day.Date && project.TargetEndDate.Value.Date > day.Date))
                .OrderBy(project => project.TargetEndDate ?? project.StartDate)
                .ToList();

            <div class="calendar-day @(isOutsideMonth ? "is-muted" : "") @(isToday ? "is-today" : "")">
                <div class="calendar-day-number">@day.Day</div>
                <div class="calendar-events">
                    @foreach (var project in dayProjects.Take(4))
                    {
                        var marker = project.StartDate?.Date == day.Date
                            ? "Başlangıç"
                            : project.TargetEndDate?.Date == day.Date
                                ? "Hedef"
                                : "Süreç";
                        <a class="calendar-event status-@project.Status.ToString().ToLowerInvariant()" asp-action="Details" asp-route-id="@project.Id" title="@project.Code - @project.Name">
                            <span>@marker</span>
                            <strong>@project.Code</strong>
                        </a>
                    }
                    @if (dayProjects.Count > 4)
                    {
                        <small class="calendar-more">+@(dayProjects.Count - 4) proje</small>
                    }
                </div>
            </div>
        }
    </div>
</section>
