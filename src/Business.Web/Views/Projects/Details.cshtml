@model Business.Web.ViewModels.ProjectDetailsViewModel
@{
    ViewData["Title"] = Model.Project.Code;
    var visibleProjectTasks = ViewBag.VisibleProjectTasks as IReadOnlyList<ProjectTask> ?? [];
    var taskHierarchyLabels = ViewBag.TaskHierarchyLabels as IReadOnlyDictionary<Guid, string> ?? new Dictionary<Guid, string>();
    var canCreateTask = User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksCreate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksManage) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canCreateOrder = User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingCreate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingManage);
    var canManageMaterialRequests = User.HasClaim(AppClaimTypes.Permission, AppPermissions.MaterialRequestsManage);
    var canDeleteProject = User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsDelete) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var currentReturnUrl = Context.Request.Path.ToString();
}

<section class="project-header">
    <div>
        <p class="section-kicker">@Model.Project.Code</p>
        <h2>@Model.Project.Name</h2>
        <p><strong>Müşteri:</strong> @(Model.Project.Customer?.Name ?? Model.Project.CustomerName ?? "Müşteri bilgisi yok.")</p>
        <p><strong>Açıklama:</strong> @(Model.Project.Description ?? "Açıklama bilgisi yok.")</p>
        <p><strong>Oluşturulma tarihi:</strong> @Model.Project.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
    </div>
    <div class="project-header-actions">
        <span class="status-pill">@Model.Project.Status.ToDisplayName()</span>
        <a class="btn btn-outline-primary btn-sm" asp-controller="ProjectDrive" asp-action="Index" asp-route-projectId="@Model.Project.Id">Dosyaları Yönet</a>
        <a class="btn btn-outline-secondary btn-sm" asp-controller="PersonalNotes" asp-action="Create" asp-route-projectId="@Model.Project.Id">Bana özel not ekle</a>
        <a class="btn btn-outline-secondary btn-sm" asp-controller="PersonalTasks" asp-action="Create" asp-route-projectId="@Model.Project.Id">Bana özel görev ekle</a>
        @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsUpdate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage))
        {
            <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@Model.Project.Id">Projeyi Düzenle</a>
        }
        @if (canDeleteProject)
        {
            <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@Model.Project.Id">Sil</a>
        }
    </div>
</section>

<div class="dashboard-grid">
    <section class="panel-block">
        <div class="panel-heading">
            <div>
                <p class="section-kicker">Görevler</p>
                <h2>Proje işleri</h2>
            </div>
            <div class="toolbar-actions">
                <a class="btn btn-outline-primary btn-sm" asp-controller="ProjectTasks" asp-action="All" asp-route-projectId="@Model.Project.Id">Tümünü İncele</a>
                @if (canCreateTask)
                {
                    <a class="btn btn-primary btn-sm" asp-controller="ProjectTasks" asp-action="Create" asp-route-projectId="@Model.Project.Id">Yeni Görev Ekle</a>
                }
            </div>
        </div>
        <div class="list-stack">
            @foreach (var task in visibleProjectTasks.Take(6))
            {
                <a class="list-row list-row-link" asp-controller="ProjectTasks" asp-action="Details" asp-route-id="@task.Id">
                    <span>
                        <strong>@task.Title</strong>
                        <small>
                            @(task.TaskCategory?.Name ?? "Kategori yok") · %@task.ProgressPercent · @task.Assignments.Count atanan
                            @if (task.ParentTaskId.HasValue)
                            {
                                var treeText = taskHierarchyLabels.TryGetValue(task.Id, out var hierarchyLabel)
                                    ? hierarchyLabel.Replace("Hiyerarşi: ", "")
                                    : "Alt görev";
                                <span class="task-tree-badge" title="Alt görev">↳ @treeText</span>
                            }
                        </small>
                    </span>
                    <span class="status-pill">@task.Status.ToDisplayName()</span>
                </a>
            }
            @if (!visibleProjectTasks.Any())
            {
                <p class="empty-note">Bu projeye bağlı görev yok.</p>
            }
        </div>
    </section>

    @if (Model.CanViewPurchasing)
    {
        <section class="panel-block">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Satın alma</p>
                    <h2>Siparişler</h2>
                </div>
                <div class="toolbar-actions">
                    <a class="btn btn-outline-primary btn-sm" asp-controller="PurchaseOrders" asp-action="All" asp-route-projectId="@Model.Project.Id">Tümünü İncele</a>
                    @if (canCreateOrder)
                    {
                        <a class="btn btn-outline-secondary btn-sm" asp-controller="PurchaseOrders" asp-action="QuickCreate" asp-route-projectId="@Model.Project.Id" asp-route-returnUrl="@currentReturnUrl">Hızlı sipariş</a>
                        <a class="btn btn-primary btn-sm" asp-controller="PurchaseOrders" asp-action="Create" asp-route-projectId="@Model.Project.Id">Yeni Sipariş Ekle</a>
                    }
                </div>
            </div>
            @if (canCreateOrder)
            {
                <details class="inline-quick-panel">
                    <summary>Üstten hızlı sipariş ekle</summary>
                    <form asp-controller="PurchaseOrders" asp-action="Create" method="post" class="quick-inline-grid mt-3" data-inline-order-form>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                        <input type="hidden" name="ProjectId" value="@Model.Project.Id" />
                        <input type="hidden" name="OrderDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="Status" value="@PurchaseOrderStatus.Requested" />
                        <div>
                            <label class="form-label">Sipariş içeriği</label>
                            <input name="Content" class="form-control" required maxlength="600" placeholder="Ne sipariş edilecek?" />
                        </div>
                        <div>
                            <label class="form-label">Tedarikçi</label>
                            <input name="SupplierNameInput" class="form-control" data-free-text-select data-free-text-hide-empty="true" data-target-id="ProjectInlineSupplierId" data-list-id="projectInlineSupplierOptions" placeholder="Tedarikçi ara veya yeni ekle" autocomplete="off" />
                            <input id="ProjectInlineSupplierId" name="SupplierId" type="hidden" />
                        </div>
                        <div>
                            <label class="form-label">Malzeme</label>
                            <input name="MaterialNameInput" class="form-control" data-free-text-select data-free-text-hide-empty="true" data-target-id="ProjectInlineMaterialId" data-list-id="projectInlineMaterialOptions" placeholder="Malzeme ara veya yeni ekle" autocomplete="off" />
                            <input id="ProjectInlineMaterialId" name="MaterialId" type="hidden" />
                        </div>
                        <div>
                            <label class="form-label">Adet / Miktar</label>
                            <input name="Quantity" type="number" step="0.0001" class="form-control" data-inline-order-quantity />
                        </div>
                        <div>
                            <label class="form-label">Birim</label>
                            <input name="Unit" class="form-control" maxlength="40" placeholder="Adet, kg, litre" />
                        </div>
                        <div>
                            <label class="form-label">Birim fiyat</label>
                            <input name="UnitPrice" type="number" step="0.0001" class="form-control" data-inline-order-unit-price />
                        </div>
                        <div>
                            <label class="form-label">Sipariş tutarı</label>
                            <input name="OrderTotal" type="number" step="0.0001" class="form-control" data-inline-order-total />
                        </div>
                        <div>
                            <label class="form-label">Para birimi</label>
                            <select name="Currency" class="form-select" asp-items="CurrencyMetadata.GetSelectList()"></select>
                        </div>
                        <div>
                            <label class="form-label">Beklenen varış</label>
                            <input name="ExpectedArrivalDate" type="date" class="form-control" />
                        </div>
                        <div class="quick-inline-grid-wide">
                            <label class="form-label">Not</label>
                            <input name="Notes" class="form-control" maxlength="2000" />
                        </div>
                        <div class="quick-inline-actions">
                            <button class="btn btn-primary" type="submit">Hızlı kaydet</button>
                        </div>
                    </form>
                </details>
            }
            <div class="list-stack">
                @foreach (var order in Model.Project.PurchaseOrders.OrderByDescending(x => x.CreatedAt).Take(6))
                {
                    <a class="list-row list-row-link" asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@order.Id">
                        <span>
                            <strong>@order.Content</strong>
                            <small>@order.QuantityText · @(order.Supplier?.Name ?? "Tedarikçi yok") · @(order.Material?.Name ?? "Malzeme yok")</small>
                        </span>
                        <span class="status-pill">@order.Status.ToDisplayName()</span>
                    </a>
                }
                @if (!Model.Project.PurchaseOrders.Any())
                {
                    <p class="empty-note">Bu projeye bağlı sipariş yok.</p>
                }
            </div>
        </section>
    }

    <section class="panel-block">
        <div class="panel-heading">
            <div>
                <p class="section-kicker">Malzeme</p>
                <h2>İhtiyaç listesi</h2>
            </div>
            <div class="toolbar-actions">
                <a class="btn btn-outline-primary btn-sm" asp-controller="MaterialRequests" asp-action="All" asp-route-projectId="@Model.Project.Id">Tümünü İncele</a>
                @if (canManageMaterialRequests)
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="MaterialRequests" asp-action="QuickCreate" asp-route-projectId="@Model.Project.Id" asp-route-returnUrl="@currentReturnUrl">Hızlı ihtiyaç</a>
                    <a class="btn btn-primary btn-sm" asp-controller="MaterialRequests" asp-action="Create" asp-route-projectId="@Model.Project.Id" asp-route-returnUrl="@currentReturnUrl">Yeni ekle</a>
                }
            </div>
        </div>

        @if (canManageMaterialRequests)
        {
            <details class="inline-quick-panel" @(Model.Project.MaterialRequests.Any() ? null : "open")>
                <summary>Üstten hızlı ihtiyaç ekle</summary>
                <form asp-controller="MaterialRequests" asp-action="Create" method="post" class="quick-inline-grid mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProjectId" value="@Model.Project.Id" />
                    <input type="hidden" name="Status" value="@MaterialRequestStatus.Requested" />
                    <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                    <div>
                        <label class="form-label">İstenen malzeme</label>
                        <input name="RequestedItem" class="form-control" required maxlength="420" placeholder="Ne gerekiyor?" />
                    </div>
                    <div>
                        <label class="form-label">Malzeme sınıfı</label>
                        <input name="MaterialNameInput" class="form-control" data-free-text-select data-free-text-hide-empty="true" data-target-id="ProjectRequestInlineMaterialId" data-list-id="projectInlineMaterialOptions" placeholder="Malzeme ara veya yeni ekle" autocomplete="off" />
                        <input id="ProjectRequestInlineMaterialId" name="MaterialId" type="hidden" />
                    </div>
                    <div>
                        <label class="form-label">Miktar</label>
                        <input name="Quantity" type="number" step="0.001" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label">Birim</label>
                        <input name="Unit" class="form-control" maxlength="40" placeholder="Adet, kg, metre" />
                    </div>
                    <div>
                        <label class="form-label">Miktar metni</label>
                        <input name="QuantityText" class="form-control" maxlength="80" placeholder="Örn. 12 adet" />
                    </div>
                    <div>
                        <label class="form-label">Kalite</label>
                        <input name="Quality" class="form-control" maxlength="120" />
                    </div>
                    <div>
                        <label class="form-label">Gerekli tarih</label>
                        <input name="NeededBy" type="date" class="form-control" value="@DateTime.Today.AddDays(3).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="quick-inline-grid-wide">
                        <label class="form-label">Not</label>
                        <input name="Notes" class="form-control" maxlength="2000" />
                    </div>
                    <div class="quick-inline-actions">
                        <button class="btn btn-primary" type="submit">Hızlı kaydet</button>
                    </div>
                </form>
            </details>
        }

        <div class="list-stack">
            @foreach (var request in Model.Project.MaterialRequests.OrderByDescending(x => x.CreatedAt).Take(7))
            {
                var quantityDisplay = request.QuantityText
                    ?? (request.Quantity.HasValue
                        ? string.IsNullOrWhiteSpace(request.Unit)
                            ? request.Quantity.Value.ToString("0.###")
                            : $"{request.Quantity.Value:0.###} {request.Unit}"
                        : "-");
                <a class="list-row list-row-link" asp-controller="MaterialRequests" asp-action="Details" asp-route-id="@request.Id">
                    <span>
                        <strong>@request.RequestedItem</strong>
                        <small>@quantityDisplay · @(request.Quality ?? "Kalite belirtilmedi")</small>
                    </span>
                    <span class="status-pill">@request.Status.ToDisplayName()</span>
                </a>
            }
            @if (!Model.Project.MaterialRequests.Any())
            {
                <p class="empty-note">Bu projeye bağlı ihtiyaç kaydı yok.</p>
            }
        </div>
    </section>

    @if (Model.CanViewProductionUpdates)
    {
        <section class="panel-block">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Proje</p>
                    <h2>Güncellemeler</h2>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-action="Updates" asp-route-id="@Model.Project.Id">Güncelleme Geçmişi</a>
            </div>
            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage))
            {
                <form asp-action="AddUpdate" asp-route-id="@Model.Project.Id" method="post" class="activity-form mb-3">
                    <input name="title" class="form-control" placeholder="Güncelleme başlığı" />
                    <textarea name="description" class="form-control" rows="2" placeholder="Açıklama"></textarea>
                    <button class="btn btn-primary btn-sm" type="submit">Güncelleme Ekle</button>
                </form>
            }
            <div class="list-stack">
                @foreach (var update in Model.Project.Updates.OrderByDescending(x => x.CreatedAt).Take(5))
                {
                    <div class="list-row">
                        <span>
                            <strong>@update.Title</strong>
                            <small>@(string.IsNullOrWhiteSpace(update.Description) ? "Ek açıklama yok." : update.Description)</small>
                        </span>
                        <small>@update.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                }
            </div>
        </section>
    }
</div>

@if (Model.Activity is not null)
{
    @await Html.PartialAsync("_RecordActivity", Model.Activity)
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var forms = document.querySelectorAll('[data-inline-order-form]');
        if (!forms.length) {
            return;
        }

        function parseNumber(value) {
            if (!value) {
                return NaN;
            }

            return Number(String(value).replace(',', '.'));
        }

        forms.forEach(function (form) {
            var quantityInput = form.querySelector('[data-inline-order-quantity]');
            var unitPriceInput = form.querySelector('[data-inline-order-unit-price]');
            var totalInput = form.querySelector('[data-inline-order-total]');

            if (!quantityInput || !unitPriceInput || !totalInput) {
                return;
            }

            function updateTotal() {
                var quantity = parseNumber(quantityInput.value);
                var unitPrice = parseNumber(unitPriceInput.value);

                if (Number.isFinite(quantity) && Number.isFinite(unitPrice)) {
                    totalInput.value = Number((quantity * unitPrice).toFixed(4)).toString();
                    return;
                }

                totalInput.value = '';
            }

            quantityInput.addEventListener('input', updateTotal);
            unitPriceInput.addEventListener('input', updateTotal);
        });
    });
</script>

<datalist id="projectInlineSupplierOptions">
    @foreach (var supplier in ViewBag.Suppliers)
    {
        <option value="@supplier.Name" data-id="@supplier.Id"></option>
    }
</datalist>

<datalist id="projectInlineMaterialOptions">
    @foreach (var material in ViewBag.Materials)
    {
        <option value="@material.Name" data-id="@material.Id"></option>
    }
</datalist>
