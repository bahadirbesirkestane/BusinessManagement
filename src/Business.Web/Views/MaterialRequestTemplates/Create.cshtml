@model MaterialRequestTemplateFormViewModel
@{
    ViewData["Title"] = "Yeni İhtiyaç Şablonu";
}

<section class="panel-block form-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Malzeme ihtiyaçları</p>
            <h2>Yeni ihtiyaç şablonu</h2>
        </div>
    </div>

    <form asp-action="Create" method="post" class="app-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_TemplateForm" model="Model" />
        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-action="Index">Vazgeç</a>
            <button class="btn btn-primary" type="submit">Kaydet</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
