@model IReadOnlyList<StockItem>
@{
    var title = ViewData["Title"]?.ToString() ?? "Stok Listesi";
    var canManageStock = User.HasClaim(AppClaimTypes.Permission, AppPermissions.StockManage) || User.IsInRole(AppRoles.Admin);
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Stok / Depo</p>
            <h2>@title</h2>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Stok Durumu</a>
    </div>
    @if (canManageStock)
    {
        <form id="bulkDeleteForm" asp-action="BulkDelete" method="post" class="bulk-action-bar smart-bulk-bar" data-bulk-panel="bulkDeleteForm" hidden>
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <span class="bulk-selection-count" data-bulk-count="bulkDeleteForm">0 kayıt seçildi</span>
            <div class="bulk-bar-actions">
                <button class="btn btn-outline-secondary btn-sm" type="button" data-bulk-clear="bulkDeleteForm">Seçimi temizle</button>
                <button class="btn btn-outline-danger btn-sm" type="submit" data-bulk-submit="bulkDeleteForm">Seçilenleri sil</button>
            </div>
        </form>
    }
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    @if (canManageStock)
                    {
                        <th class="bulk-check-cell">
                            <input type="checkbox" data-bulk-toggle="bulkDeleteForm" aria-label="Tüm stok kalemlerini seç" />
                        </th>
                    }
                    <th>Malzeme</th>
                    <th>Tür</th>
                    <th>Kalınlık</th>
                    <th>Ölçü</th>
                    <th>Adet / Miktar</th>
                    <th>Durum</th>
                    <th>Konum</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="status-row status-@item.Status.ToString().ToLowerInvariant()">
                        @if (canManageStock)
                        {
                            <td><input type="checkbox" name="ids" value="@item.Id" form="bulkDeleteForm" /></td>
                        }
                        <td><strong>@(item.Material?.Name ?? "-")</strong></td>
                        <td>@item.Name</td>
                        <td>@(item.Thickness ?? "-")</td>
                        <td>@(item.Dimensions ?? "-")</td>
                        <td>@(item.QuantityText ?? item.Quantity?.ToString("0.###") ?? "-") @(item.Unit ?? "")</td>
                        <td><span class="status-pill status-@item.Status.ToString().ToLowerInvariant()">@item.Status.ToDisplayName()</span></td>
                        <td>@(item.Location ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
