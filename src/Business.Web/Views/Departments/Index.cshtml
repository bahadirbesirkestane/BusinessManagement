@model IReadOnlyList<Department>
@{
    ViewData["Title"] = "Departmanlar";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Kullanıcılar ve Yetkiler</p>
            <h2>Departmanlar</h2>
        </div>
        <a class="btn btn-primary" asp-action="Create">Departman Ekle</a>
    </div>
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead><tr><th>Departman</th><th>Açıklama</th><th>Durum</th><th></th></tr></thead>
            <tbody>
            @foreach (var department in Model)
            {
                <tr class="@(department.IsActive ? "" : "row-muted")">
                    <td><strong>@department.Name</strong></td>
                    <td>@(department.Description ?? "-")</td>
                    <td><span class="status-pill @(department.IsActive ? "status-success" : "status-danger")">@(department.IsActive ? "Aktif" : "Pasif")</span></td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@department.Id">Düzenle</a>
                        <form class="inline-form" asp-action="Delete" asp-route-id="@department.Id" method="post">
                            <button class="btn btn-sm btn-outline-danger" type="submit">Sil</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
