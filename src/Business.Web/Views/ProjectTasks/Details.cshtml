@model ProjectTask
@{
    var taskUpdates = Model.Updates
        .OrderByDescending(x => x.CreatedAt)
        .ToList();
    var returnUrl = ViewBag.ReturnUrl as string ?? $"{Context.Request.Path}{Context.Request.QueryString}";
    var canCompleteTask = User.IsInRole(AppRoles.Admin) ||
        User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksComplete);
    var canDeleteTask = User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksDelete) ||
        User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksManage) ||
        User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var createdByName = ViewBag.CreatedByName as string;
    var updatedByName = ViewBag.UpdatedByName as string;
    ViewData["Title"] = "Görev Detayı";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">
                @(Model.Project?.Code
                    ?? Model.Customer?.Name
                    ?? Model.ManualProjectName
                    ?? Model.ManualCustomerName
                    ?? "Genel")
            </p>
            <h2>@Model.Title</h2>
        </div>
        <div class="project-header-actions">
            <a class="btn btn-outline-secondary btn-sm" asp-controller="PersonalNotes" asp-action="Create" asp-route-projectTaskId="@Model.Id">Bana özel not ekle</a>
            <a class="btn btn-outline-secondary btn-sm" asp-controller="PersonalTasks" asp-action="Create" asp-route-projectTaskId="@Model.Id">Bana özel görev ekle</a>
            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksChangeStatus) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksManage) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage))
            {
                <form asp-action="UpdateStatus" method="post" class="inline-status-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <select name="status" class="status-select status-@Model.Status.ToString().ToLowerInvariant()" onchange="this.form.submit()" aria-label="Görev durumu">
                        @foreach (WorkTaskStatus status in Enum.GetValues<WorkTaskStatus>())
                        {
                            if (status == WorkTaskStatus.Done && !canCompleteTask && Model.Status != WorkTaskStatus.Done)
                            {
                                continue;
                            }
                            <option value="@status" selected="@(Model.Status == status)">@status.ToDisplayName()</option>
                        }
                    </select>
                </form>
            }
            else
            {
                <span class="status-pill status-@Model.Status.ToString().ToLowerInvariant()">@Model.Status.ToDisplayName()</span>
            }
            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksUpdate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksManage) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage))
            {
                <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl">Düzenle</a>
            }
            @if (Model.Status != WorkTaskStatus.InReview && Model.Status != WorkTaskStatus.Done)
            {
                <form asp-action="SubmitForReview" asp-route-id="@Model.Id" method="post" class="inline-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button class="btn btn-outline-primary btn-sm" type="submit">Kontrole Gönder</button>
                </form>
            }
            @if (canCompleteTask && Model.Status != WorkTaskStatus.Done)
            {
                <form asp-action="Complete" asp-route-id="@Model.Id" method="post" class="inline-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button class="btn btn-success btn-sm" type="submit">Tamamlandı Yap</button>
                </form>
            }
            @if (canDeleteTask)
            {
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="inline-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button class="btn btn-outline-danger btn-sm" type="submit">Sil</button>
                </form>
            }
        </div>
    </div>
    <div class="mb-3">
        <div class="progress">
            <div class="progress-bar" style="width:@Model.ProgressPercent%">%@Model.ProgressPercent</div>
        </div>
    </div>
    <dl class="row">
        <dt class="col-sm-3">Görev Sahibi</dt><dd class="col-sm-9">@ViewBag.ResponsibleName</dd>
        <dt class="col-sm-3">Atanan kişiler</dt><dd class="col-sm-9">@(((IReadOnlyList<string>)ViewBag.AssignedUsers).Any() ? string.Join(", ", (IReadOnlyList<string>)ViewBag.AssignedUsers) : "-")</dd>
        <dt class="col-sm-3">Kategori</dt><dd class="col-sm-9">@(Model.TaskCategory?.Name ?? "-")</dd>
        <dt class="col-sm-3">Proje</dt><dd class="col-sm-9">@(Model.Project?.Name ?? Model.ManualProjectName ?? "-")</dd>
        <dt class="col-sm-3">Müşteri</dt><dd class="col-sm-9">@(Model.Project?.Customer?.Name ?? Model.Customer?.Name ?? Model.ManualCustomerName ?? "-")</dd>
        <dt class="col-sm-3">Öncelik</dt><dd class="col-sm-9">@Model.Priority.ToDisplayName()</dd>
        <dt class="col-sm-3">Başlangıç</dt><dd class="col-sm-9">@(Model.StartDate?.ToString("dd.MM.yyyy") ?? "-")</dd>
        <dt class="col-sm-3">Termin</dt><dd class="col-sm-9">@(Model.DueDate?.ToString("dd.MM.yyyy") ?? "-")</dd>
        <dt class="col-sm-3">Oluşturma</dt><dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
        <dt class="col-sm-3">Görevi oluşturan</dt><dd class="col-sm-9">@(createdByName ?? "-")</dd>
        <dt class="col-sm-3">Son güncelleme</dt><dd class="col-sm-9">@(Model.UpdatedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>
        <dt class="col-sm-3">Güncelleyen</dt><dd class="col-sm-9">@(updatedByName ?? "-")</dd>
        <dt class="col-sm-3">Açıklama</dt><dd class="col-sm-9">@(Model.Description ?? "-")</dd>
    </dl>
</section>

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Görev geçmişi</p>
            <h2>Görev Güncellemeleri</h2>
        </div>
        <a class="btn btn-outline-primary btn-sm" asp-action="Updates" asp-route-id="@Model.Id">Güncelleme Geçmişi</a>
    </div>

    @if (!taskUpdates.Any())
    {
        <p class="empty-note">Bu görev için henüz güncelleme kaydı yok.</p>
    }
    else
    {
        <div class="timeline-list">
            @foreach (var update in taskUpdates.Take(5))
            {
                <div class="timeline-item">
                    <div>
                        <strong>@update.Title</strong>
                        <span>@update.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(update.Description))
                    {
                        <p>@update.Description</p>
                    }
                </div>
            }
        </div>
    }
</section>

@if (ViewBag.Activity is Business.Web.ViewModels.RecordActivityViewModel activity)
{
    @await Html.PartialAsync("_RecordActivity", activity)
}
