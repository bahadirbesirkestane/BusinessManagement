@model IReadOnlyList<ProjectTask>
@{
    ViewData["Title"] = "Görevler";
    var userNames = (IReadOnlyDictionary<string, string>)(ViewBag.UserNames ?? new Dictionary<string, string>());
    var listAction = (string)(ViewBag.ListAction ?? (ViewBag.AssignedToMe == true ? "AssignedToMe" : "Index"));
    var canCreateTask = User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksCreate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canUpdateTask = User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksUpdate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canChangeTaskStatus = User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksChangeStatus) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canCompleteTask = User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksComplete) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canUseBulkActions = canUpdateTask || canChangeTaskStatus || User.IsInRole(AppRoles.Admin);
    var isDeferredLoad = ViewBag.IsDeferredLoad == true;
    var hasMore = ViewBag.HasMore == true;
    var currentTake = (int)(ViewBag.CurrentTake ?? 50);
    var nextTake = (int)(ViewBag.NextTake ?? (currentTake + 50));
    var requiresManualLoad = isDeferredLoad;
    var showAll = ViewBag.ShowAll == true;
    var isArchiveList = ViewBag.IsArchiveList == true;
    var statusOptions = (IReadOnlyList<WorkTaskStatus>)(ViewBag.StatusOptions ?? Enum.GetValues<WorkTaskStatus>().ToList());
    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var defaultProjectId = ViewBag.ProjectId?.ToString();
    var moreRoute = new Dictionary<string, string?>();
    var showAllRoute = new Dictionary<string, string?>();
    moreRoute["projectId"] = ViewBag.ProjectId?.ToString();
    moreRoute["q"] = ViewBag.FilterQ;
    moreRoute["status"] = ViewBag.FilterStatus?.ToString();
    moreRoute["priority"] = ViewBag.FilterPriority?.ToString();
    moreRoute["categoryId"] = ViewBag.FilterCategoryId?.ToString();
    moreRoute["customerId"] = ViewBag.FilterCustomerId?.ToString();
    moreRoute["responsibleUserId"] = ViewBag.FilterResponsibleUserId;
    moreRoute["assignedUserId"] = ViewBag.FilterAssignedUserId;
    moreRoute["sort"] = ViewBag.Sort;
    if (requiresManualLoad)
    {
        moreRoute["load"] = "true";
        showAllRoute["load"] = "true";
    }
    moreRoute["take"] = nextTake.ToString();
    showAllRoute["projectId"] = ViewBag.ProjectId?.ToString();
    showAllRoute["q"] = ViewBag.FilterQ;
    showAllRoute["status"] = ViewBag.FilterStatus?.ToString();
    showAllRoute["priority"] = ViewBag.FilterPriority?.ToString();
    showAllRoute["categoryId"] = ViewBag.FilterCategoryId?.ToString();
    showAllRoute["customerId"] = ViewBag.FilterCustomerId?.ToString();
    showAllRoute["responsibleUserId"] = ViewBag.FilterResponsibleUserId;
    showAllRoute["assignedUserId"] = ViewBag.FilterAssignedUserId;
    showAllRoute["sort"] = ViewBag.Sort;
    showAllRoute["showAll"] = "true";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Görevler</p>
            <h2>@(ViewBag.TaskListTitle ?? "Tüm görevler")</h2>
            <p class="record-count">@(isDeferredLoad ? "Liste henüz yüklenmedi." : $"Gösterilen kayıt sayısı: {Model.Count}")</p>
        </div>
        <div class="toolbar-actions">
            @if (isArchiveList)
            {
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index" asp-route-projectId="@ViewBag.ProjectId">Aktif liste</a>
                <a class="btn btn-outline-primary btn-sm" asp-action="DownloadArchive">Arşivi indir</a>
            }
            else if (!string.Equals(listAction, "AssignedToMe", StringComparison.OrdinalIgnoreCase))
            {
                <a class="btn btn-outline-secondary btn-sm" asp-action="Archived" asp-route-projectId="@ViewBag.ProjectId">Arşiv</a>
            }
            @if (canCreateTask)
            {
                <a class="btn btn-primary" asp-action="Create" asp-route-projectId="@ViewBag.ProjectId" asp-route-returnUrl="@currentReturnUrl">Görev ekle</a>
            }
        </div>
    </div>

    <form id="tasksFilterForm" asp-action="@listAction" method="get" class="list-filter-bar">
        @if (ViewBag.ProjectId is not null)
        {
            <input type="hidden" name="projectId" value="@ViewBag.ProjectId" />
        }
        @if (requiresManualLoad)
        {
            <input type="hidden" name="load" value="true" />
        }
        <input type="hidden" name="take" value="@currentTake" />
        <div class="filter-field filter-search">
            <span class="filter-icon" aria-hidden="true">⌕</span>
            <input name="q" value="@ViewBag.FilterQ" class="form-control form-control-sm" placeholder="Görev, açıklama veya bağlantı ara" />
        </div>
        <select name="status" class="form-select form-select-sm">
            <option value="">Durum</option>
            @foreach (var item in statusOptions)
            {
                <option value="@item" selected="@(ViewBag.FilterStatus == item)">@item.ToDisplayName()</option>
            }
        </select>
        <select name="priority" class="form-select form-select-sm">
            <option value="">Öncelik</option>
            @foreach (ProjectPriority item in Enum.GetValues<ProjectPriority>())
            {
                <option value="@item" selected="@(ViewBag.FilterPriority == item)">@item.ToDisplayName()</option>
            }
        </select>
        <select name="categoryId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Kategori ara veya seç">
            <option value="">Kategori</option>
            @foreach (var category in ViewBag.FilterTaskCategories)
            {
                <option value="@category.Id" selected="@(ViewBag.FilterCategoryId == category.Id)">@category.Name</option>
            }
        </select>
        <select name="customerId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Müşteri ara veya seç">
            <option value="">Müşteri</option>
            @foreach (var customer in ViewBag.FilterCustomers)
            {
                <option value="@customer.Id" selected="@(ViewBag.FilterCustomerId == customer.Id)">@customer.Name</option>
            }
        </select>
        <select name="responsibleUserId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Sorumlu ara veya seç">
            <option value="">Sorumlu</option>
            @foreach (var user in ViewBag.FilterUsers)
            {
                <option value="@user.Id" selected="@(ViewBag.FilterResponsibleUserId == user.Id)">@user.FullName</option>
            }
        </select>
        <select name="assignedUserId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Atanan ara veya seç">
            <option value="">Atanan</option>
            @foreach (var user in ViewBag.FilterUsers)
            {
                <option value="@user.Id" selected="@(ViewBag.FilterAssignedUserId == user.Id)">@user.FullName</option>
            }
        </select>
        <select name="sort" class="form-select form-select-sm">
            <option value="">Sırala: Yeni</option>
            <option value="title" selected="@(ViewBag.Sort == "title")">Görev adı</option>
            <option value="due" selected="@(ViewBag.Sort == "due")">Termin</option>
            <option value="priority" selected="@(ViewBag.Sort == "priority")">Öncelik</option>
            <option value="status" selected="@(ViewBag.Sort == "status")">Durum</option>
            <option value="progress" selected="@(ViewBag.Sort == "progress")">İlerleme</option>
            <option value="created" selected="@(ViewBag.Sort == "created")">Eski kayıt</option>
        </select>
        <button class="icon-filter-button" type="submit" title="Filtrele" aria-label="Filtrele">⌕</button>
        <a class="icon-filter-button clear" asp-action="@listAction" asp-route-projectId="@ViewBag.ProjectId" title="Temizle" aria-label="Temizle">×</a>
    </form>

    @if (canCreateTask && !isArchiveList)
    {
        <details class="inline-quick-panel" @(Model.Any() ? null : "open")>
            <summary>Üstten hızlı görev ekle</summary>
            <form asp-action="Create" method="post" class="quick-inline-grid mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                <input type="hidden" name="ProgressPercent" value="0" />
                <div>
                    <label class="form-label">Görev başlığı</label>
                    <input name="Title" class="form-control" required maxlength="220" placeholder="Yapılacak işi yazın" />
                </div>
                <div>
                    <label class="form-label">Proje</label>
                    <select name="ProjectId" class="form-select" data-searchable-select data-search-placeholder="Proje ara veya seç">
                        <option value="">Genel</option>
                        @foreach (var project in ViewBag.FilterProjects)
                        {
                            <option value="@project.Id" selected="@(defaultProjectId == project.Id.ToString())">@project.Code - @project.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Müşteri</label>
                    <select name="CustomerId" class="form-select" data-searchable-select data-search-placeholder="Müşteri ara veya seç">
                        <option value="">Genel</option>
                        @foreach (var customer in ViewBag.FilterCustomers)
                        {
                            <option value="@customer.Id">@customer.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Kategori</label>
                    <select name="TaskCategoryId" class="form-select" data-searchable-select data-search-placeholder="Kategori ara veya seç">
                        <option value="">Seçilmedi</option>
                        @foreach (var category in ViewBag.FilterTaskCategories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Sorumlu</label>
                    <select name="ResponsibleUserId" class="form-select" data-searchable-select data-search-placeholder="Sorumlu ara veya seç">
                        <option value="">Seçilmedi</option>
                        @foreach (var user in ViewBag.FilterUsers)
                        {
                            <option value="@user.Id">@user.FullName</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Durum</label>
                    <select name="Status" class="form-select">
                        @foreach (WorkTaskStatus status in Enum.GetValues<WorkTaskStatus>())
                        {
                            if (status == WorkTaskStatus.Done && !canCompleteTask)
                            {
                                continue;
                            }
                            <option value="@status">@status.ToDisplayName()</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Öncelik</label>
                    <select name="Priority" class="form-select">
                        @foreach (ProjectPriority priority in Enum.GetValues<ProjectPriority>())
                        {
                            <option value="@priority">@priority.ToDisplayName()</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Termin</label>
                    <input name="DueDate" type="date" class="form-control" />
                </div>
                <div class="quick-inline-actions">
                    <button class="btn btn-primary" type="submit">Hızlı kaydet</button>
                </div>
            </form>
        </details>
    }

    @if (canUseBulkActions)
    {
        <form id="bulkActionForm" method="post" class="bulk-action-bar smart-bulk-bar" data-bulk-panel="bulkActionForm" hidden>
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <span class="bulk-selection-count" data-bulk-count="bulkActionForm">0 kayıt seçildi</span>
            <div class="bulk-bar-actions">
                <button class="btn btn-outline-secondary btn-sm" type="button" data-bulk-clear="bulkActionForm">Seçimi temizle</button>
                @if (canUpdateTask)
                {
                    <button class="btn btn-outline-primary btn-sm" type="submit" formaction="@Url.Action("BulkArchive")" name="archived" value="@(isArchiveList ? "false" : "true")">
                        @(isArchiveList ? "Seçilenleri aktife al" : "Seçilenleri arşivle")
                    </button>
                }
                @if (canChangeTaskStatus && !isArchiveList)
                {
                    <select class="form-select form-select-sm" name="status" aria-label="Toplu görev durumu">
                        @foreach (WorkTaskStatus status in Enum.GetValues<WorkTaskStatus>())
                        {
                            if (status == WorkTaskStatus.Done && !canCompleteTask)
                            {
                                continue;
                            }
                            <option value="@status">@status.ToDisplayName()</option>
                        }
                    </select>
                    <button class="btn btn-outline-secondary btn-sm" type="submit" formaction="@Url.Action("BulkUpdateStatus")">Durumu uygula</button>
                }
                @if (User.IsInRole(AppRoles.Admin))
                {
                    <button class="btn btn-outline-danger btn-sm" type="submit" formaction="@Url.Action("BulkDelete")" data-bulk-submit="bulkActionForm">Seçilenleri sil</button>
                }
            </div>
        </form>
    }

    @if (isDeferredLoad)
    {
        <div class="empty-note empty-note-empty-state">
            <div>
                <strong>Görev listesi hazır bekliyor.</strong>
                <span>Sistem yükünü azaltmak için görevler sayfa açılır açılmaz yüklenmez. Filtre seçip verileri getirin.</span>
            </div>
            <div class="empty-state-actions">
                <button class="btn btn-primary btn-sm" type="submit" form="tasksFilterForm">Verileri getir</button>
                <a class="btn btn-outline-secondary btn-sm" asp-action="@listAction" asp-all-route-data="showAllRoute">Tümünü göster</a>
            </div>
        </div>
    }
    else if (!Model.Any())
    {
        <div class="empty-note empty-note-empty-state">
            <div>
                <strong>Uygun görev bulunamadı.</strong>
                <span>@(isArchiveList ? "Arşivde gösterilecek görev yok." : "Filtreleri temizleyin ya da tamamlanan görevler için ayrı sayfayı açın.")</span>
            </div>
            @if (canCreateTask)
            {
                <a class="btn btn-primary btn-sm" asp-action="Create" asp-route-projectId="@ViewBag.ProjectId" asp-route-returnUrl="@currentReturnUrl">Yeni görev oluştur</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive table-responsive-menu">
            <table class="table app-table align-middle">
                <thead>
                    <tr>
                        <th>Görev</th>
                        <th>Bağlantı</th>
                        @if (canUseBulkActions)
                        {
                            <th class="bulk-check-cell">
                                <input type="checkbox" data-bulk-toggle="bulkActionForm" aria-label="Tüm görevleri seç" />
                            </th>
                        }
                        <th>Kategori</th>
                        <th>Sorumlu</th>
                        <th>Atananlar</th>
                        <th>Durum</th>
                        <th>İlerleme</th>
                        <th>Öncelik</th>
                        <th>Tarih</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model)
                    {
                        var returnUrl = currentReturnUrl;
                        var assignedNames = task.Assignments
                            .Select(x => userNames.TryGetValue(x.UserId, out var assignedName) ? assignedName : null)
                            .Where(x => !string.IsNullOrWhiteSpace(x))
                            .ToList();
                        var previewDescription = !string.IsNullOrWhiteSpace(task.Description)
                            ? task.Description
                            : "Bu görev için açıklama girilmemiş. Detay sayfasından güncellemeleri ve dosyaları inceleyebilirsiniz.";
                        <tr class="status-row status-@task.Status.ToString().ToLowerInvariant()"
                            data-row-link="@Url.Action("Details", new { id = task.Id, returnUrl })"
                            data-preview-group="tasks-list"
                            data-preview-title="@task.Title"
                            data-preview-subtitle="Bağlantı: @(task.Project?.Code ?? task.Customer?.Name ?? task.ManualProjectName ?? task.ManualCustomerName ?? "Genel")"
                            data-preview-meta="Sorumlu: @(!string.IsNullOrWhiteSpace(task.ResponsibleUserId) && userNames.TryGetValue(task.ResponsibleUserId, out var responsibleName) ? responsibleName : "Atanmadı") | İlerleme: %@task.ProgressPercent"
                            data-preview-description="@previewDescription"
                            data-preview-status="@task.Status.ToDisplayName()">
                            <td><strong>@task.Title</strong></td>
                            <td>@(task.Project?.Code ?? task.Customer?.Name ?? task.ManualProjectName ?? task.ManualCustomerName ?? "Genel")</td>
                            @if (canUseBulkActions)
                            {
                                <td><input type="checkbox" name="ids" value="@task.Id" form="bulkActionForm" /></td>
                            }
                            <td>@(task.TaskCategory?.Name ?? "-")</td>
                            <td>@(!string.IsNullOrWhiteSpace(task.ResponsibleUserId) && userNames.TryGetValue(task.ResponsibleUserId, out var responsibleDisplay) ? responsibleDisplay : "-")</td>
                            <td>@(assignedNames.Any() ? string.Join(", ", assignedNames) : "-")</td>
                            <td>
                                @if (canChangeTaskStatus && !isArchiveList)
                                {
                                    <form asp-action="UpdateStatus" method="post" class="inline-status-form">
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <select name="status" class="status-select status-@task.Status.ToString().ToLowerInvariant()" onchange="this.form.submit()" aria-label="Görev durumu">
                                            @foreach (WorkTaskStatus status in Enum.GetValues<WorkTaskStatus>())
                                            {
                                                if (status == WorkTaskStatus.Done && !canCompleteTask)
                                                {
                                                    continue;
                                                }
                                                <option value="@status" selected="@(task.Status == status)">@status.ToDisplayName()</option>
                                            }
                                        </select>
                                    </form>
                                }
                                else
                                {
                                    <span class="status-pill status-@task.Status.ToString().ToLowerInvariant()">@task.Status.ToDisplayName()</span>
                                }
                            </td>
                            <td>
                                <div class="progress slim-progress">
                                    <div class="progress-bar" style="width:@task.ProgressPercent%"></div>
                                </div>
                                <small class="text-muted">%@task.ProgressPercent</small>
                            </td>
                            <td><span class="priority-pill priority-@task.Priority.ToString().ToLowerInvariant()">@task.Priority.ToDisplayName()</span></td>
                            <td>@task.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end action-cell">
                                <div class="action-shell">
                                    <button class="preview-trigger" type="button" data-preview-trigger title="Hızlı önizleme" aria-label="Hızlı önizleme">i</button>
                                    <details class="action-menu">
                                        <summary aria-label="Görev işlemleri">...</summary>
                                        <div class="action-menu-list">
                                            <a asp-action="Details" asp-route-id="@task.Id" asp-route-returnUrl="@returnUrl">Detay</a>
                                            @if (!isArchiveList && task.Status != WorkTaskStatus.InReview && task.Status != WorkTaskStatus.Done)
                                            {
                                                <form asp-action="SubmitForReview" asp-route-id="@task.Id" method="post" class="inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button class="link-button" type="submit">Kontrole gönder</button>
                                                </form>
                                            }
                                            @if (!isArchiveList && canCompleteTask)
                                            {
                                                <form asp-action="Complete" asp-route-id="@task.Id" method="post" class="inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button class="link-button" type="submit">Tamamlandı yap</button>
                                                </form>
                                            }
                                            @if (canUpdateTask)
                                            {
                                                <a asp-action="Edit" asp-route-id="@task.Id" asp-route-returnUrl="@returnUrl">Düzenle</a>
                                                <form asp-action="Archive" asp-route-id="@task.Id" method="post" class="inline-form">
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <input type="hidden" name="archived" value="@(isArchiveList ? "false" : "true")" />
                                                    <button class="link-button" type="submit">@(isArchiveList ? "Aktife al" : "Arşivle")</button>
                                                </form>
                                            }
                                            @if (User.IsInRole(AppRoles.Admin))
                                            {
                                                <form asp-action="Delete" asp-route-id="@task.Id" method="post" class="inline-form">
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                    <button class="link-button text-danger" type="submit">Sil</button>
                                                </form>
                                            }
                                        </div>
                                    </details>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (hasMore || showAll)
        {
            <div class="list-load-more">
                @if (hasMore)
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-action="@listAction" asp-all-route-data="moreRoute">Daha fazla göster</a>
                }
                @if (!showAll)
                {
                    <a class="btn btn-outline-primary btn-sm" asp-action="@listAction" asp-all-route-data="showAllRoute">Tümünü göster</a>
                }
            </div>
        }
    }
</section>

<div class="compact-preview-popover" data-compact-preview hidden>
    <span class="list-preview-status" data-preview-status></span>
    <h3 data-preview-title></h3>
    <p class="list-preview-subtitle" data-preview-subtitle></p>
    <p class="list-preview-meta" data-preview-meta></p>
    <p class="list-preview-description" data-preview-description></p>
</div>
