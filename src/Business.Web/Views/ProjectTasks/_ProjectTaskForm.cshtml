@model ProjectTask
@{
    var returnUrl = ViewBag.ReturnUrl as string;
    var isCreateMode = string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "Create", StringComparison.OrdinalIgnoreCase);
    var formStatusOptions = (IReadOnlyList<WorkTaskStatus>)(ViewBag.FormStatusOptions ?? Enum.GetValues<WorkTaskStatus>().ToList());
    var sendTaskEmail = ViewBag.SendTaskEmail is bool sendMailValue && sendMailValue;
    var emailIncludeContent = ViewBag.EmailIncludeContent is bool includeContentValue ? includeContentValue : true;
    var emailIncludeAttachments = ViewBag.EmailIncludeAttachments is bool includeAttachmentsValue && includeAttachmentsValue;
    var taskMailRecipientsConfigured = ViewBag.TaskMailRecipientsConfigured is bool recipientsConfigured && recipientsConfigured;
    var taskMailRecipientSummary = ViewBag.TaskMailRecipientSummary as string;
}

<section class="panel-block form-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Görevler</p>
            <h2>@ViewData["Title"]</h2>
        </div>
    </div>
    <form method="post" enctype="multipart/form-data" class="app-form" id="taskForm" data-file-upload-form>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div class="mb-3">
                <label asp-for="ProjectId" class="form-label">Proje</label>
                <select asp-for="ProjectId" class="form-select" data-searchable-select data-search-placeholder="Proje ara veya seç">
                    <option value="">Genel</option>
                    @foreach (var project in ViewBag.Projects)
                    {
                        <option value="@project.Id">@project.Code - @project.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="CustomerId" class="form-label">Müşteri</label>
                <select asp-for="CustomerId" class="form-select" data-searchable-select data-search-placeholder="Müşteri ara veya seç">
                    <option value="">Genel</option>
                    @foreach (var customer in ViewBag.Customers)
                    {
                        <option value="@customer.Id">@customer.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="TaskCategoryId" class="form-label">Kategori</label>
                <select asp-for="TaskCategoryId" class="form-select" data-searchable-select data-search-placeholder="Kategori ara veya seç">
                    <option value="">Seçilmedi</option>
                    @foreach (var category in ViewBag.TaskCategories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="ResponsibleUserId" class="form-label">Görev Sahibi</label>
                <select asp-for="ResponsibleUserId" class="form-select" data-searchable-select data-search-placeholder="Görev sahibi ara veya seç">
                    <option value="">Görev sahibi seçilmedi</option>
                    @foreach (var user in ViewBag.Users)
                    {
                        <option value="@user.Id">@user.FullName</option>
                    }
                </select>
            </div>
            <div class="mb-3 wide">
                <label class="form-label">Atanan Kişiler</label>
                <div class="planning-user-checks">
                    @foreach (var user in ViewBag.Users)
                    {
                        <label class="check-card">
                            <input type="checkbox" name="AssignedUserIds" value="@user.Id" checked="@Model.Assignments.Any(x => x.UserId == user.Id)" />
                            <span>@user.FullName</span>
                        </label>
                    }
                </div>
                <small class="text-muted">Birden fazla kişi seçebilirsin.</small>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label">Durum</label>
                <select asp-for="Status" class="form-select" data-task-progress-status>
                    @foreach (var status in formStatusOptions)
                    {
                        <option value="@status" selected="@(Model.Status == status)">@status.ToDisplayName()</option>
                    }
                </select>
            </div>
            @if (User.IsInRole(AppRoles.Admin))
            {
                <div class="mb-3">
                    <label asp-for="Visibility" class="form-label">Görünürlük</label>
                    <select asp-for="Visibility" asp-items="Html.GetEnumSelectList<RecordVisibility>()" class="form-select"></select>
                </div>
            }
            <div class="mb-3 wide">
                <label asp-for="Title" class="form-label">Başlık</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Priority" class="form-label">Öncelik</label>
                <select asp-for="Priority" asp-items="Html.GetEnumSelectList<ProjectPriority>()" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label class="form-label">İlerleme (%)</label>
                <input asp-for="ProgressPercent" type="hidden" data-task-progress-value />
                <input class="form-control" value="@Model.ProgressPercent%" readonly data-task-progress-display />
                <small class="text-muted">İlerleme yüzdesi duruma göre otomatik hesaplanır.</small>
            </div>
            <div class="mb-3">
                <label asp-for="StartDate" class="form-label">Başlangıç</label>
                <input asp-for="StartDate" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="DueDate" class="form-label">Termin</label>
                <input asp-for="DueDate" type="date" class="form-control" />
            </div>
            <div class="mb-3 wide">
                <label asp-for="Description" class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3 wide">
                <label asp-for="Notes" class="form-label">Not</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>
            @if (isCreateMode)
            {
                <div class="mb-3 wide">
                    <label class="form-label">Dosyalar</label>
                    <input type="file"
                           name="files"
                           class="form-control"
                           multiple
                           data-file-upload-input
                           data-max-file-size="52428800"
                           data-max-file-size-label="50 MB"
                           accept=".pdf,.jpg,.jpeg,.png,.webp,.gif,.doc,.docx,.xls,.xlsx,.csv,.txt,.zip,.mp4,.dwg,.dxf" />
                    <small class="text-muted">Her bir dosya en fazla 50 MB olabilir.</small>
                    <div class="file-upload-status" data-file-upload-status hidden>
                        <div class="file-upload-status-text" data-file-upload-text></div>
                        <div class="file-upload-progress" data-file-upload-progress hidden>
                            <div class="file-upload-progress-bar" data-file-upload-progress-bar></div>
                        </div>
                        <div class="file-upload-list" data-file-upload-list></div>
                    </div>
                </div>

                <div class="mb-3 wide">
                    <div class="form-check form-switch">
                        <input class="form-check-input"
                               type="checkbox"
                               id="sendTaskEmail"
                               name="sendTaskEmail"
                               value="true"
                               checked="@sendTaskEmail"
                               data-task-email-toggle />
                        <label class="form-check-label" for="sendTaskEmail">Görev oluşturulunca mail gönderilsin</label>
                    </div>
                    <small class="text-muted">
                        @(taskMailRecipientsConfigured
                            ? $"Tanımlı alıcılar: {taskMailRecipientSummary}"
                            : "Henüz görev mail alıcısı tanımlanmadı. Ayarlar ekranından alıcı e-posta adreslerini kaydedebilirsin.")
                    </small>
                </div>

                <div class="mb-3 wide" data-task-email-options @(sendTaskEmail ? "" : "hidden")>
                    <div class="planning-user-checks">
                        <label class="check-card">
                            <input type="checkbox" name="emailIncludeContent" value="true" checked="@emailIncludeContent" />
                            <span>Görev içeriğini gönder</span>
                        </label>
                        <label class="check-card">
                            <input type="checkbox" name="emailIncludeAttachments" value="true" checked="@emailIncludeAttachments" />
                            <span>Yüklenen dosyaları ek olarak gönder</span>
                        </label>
                    </div>
                    <small class="text-muted">Mail içeriğinde görev başlığı, proje, müşteri, kategori, durum, öncelik, tarih ve açıklama bilgileri okunabilir biçimde gönderilir.</small>
                </div>
            }
        </div>
        <div class="form-actions">
            @if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                <a class="btn btn-outline-secondary" href="@returnUrl">Vazgeç</a>
            }
            else
            {
                <a class="btn btn-outline-secondary" asp-action="Index">Vazgeç</a>
            }
            <button class="btn btn-primary" type="submit">Kaydet</button>
        </div>
    </form>
</section>

@if (isCreateMode)
{
    <script>
        (function () {
            const toggle = document.querySelector('[data-task-email-toggle]');
            const options = document.querySelector('[data-task-email-options]');
            if (!toggle || !options) {
                return;
            }

            const sync = function () {
                options.hidden = !toggle.checked;
            };

            toggle.addEventListener('change', sync);
            sync();
        })();
    </script>
}
