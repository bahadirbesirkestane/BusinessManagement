@model IReadOnlyList<TaskCategory>
@{
    ViewData["Title"] = "Görev Kategorileri";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Tanımlar</p>
            <h2>Görev Kategorileri</h2>
        </div>
        <a class="btn btn-primary" asp-action="Create">Kategori Ekle</a>
    </div>
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    <th>Kategori</th>
                    <th>Durum</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var category in Model)
            {
                <tr class="@(category.IsActive ? "" : "row-muted")">
                    <td><span class="category-dot" style="--category-color:@category.Color"></span><strong>@category.Name</strong></td>
                    <td><span class="status-pill @(category.IsActive ? "status-success" : "status-danger")">@(category.IsActive ? "Aktif" : "Pasif")</span></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@category.Id">Düzenle</a>
                        <form asp-action="Delete" asp-route-id="@category.Id" method="post" class="inline-form">
                            <button type="submit" class="link-button">Sil</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
