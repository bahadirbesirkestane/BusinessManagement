<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - İş Yönetimi</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Business.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="brand" asp-area="" asp-controller="Dashboard" asp-action="Index">
                <span class="brand-mark">BM</span>
                <span>
                    <strong>İş Yönetimi</strong>
                    <small>Proje ve satın alma</small>
                </span>
            </a>

            <nav class="side-nav">
                <partial name="_SidebarNav" />
            </nav>

            <div class="role-note">
                <span>İş Yönetimi</span>
            </div>
        </aside>

        <section class="app-main">
            <header class="topbar">
                <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNav" aria-controls="mobileNav"
                        aria-expanded="false" aria-label="Menüyü aç">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="topbar-title">
                    <button class="back-button" type="button" data-back-button title="Geri" aria-label="Geri">‹</button>
                    <div>
                        <p class="topbar-eyebrow">Firma operasyon sistemi</p>
                        <h1>@(ViewData["Title"] ?? "Panel")</h1>
                    </div>
                </div>
                <partial name="_LoginPartial" />
            </header>

            <div class="collapse d-lg-none mobile-nav" id="mobileNav">
                <partial name="_SidebarNav" />
            </div>

            <main role="main" class="content-wrap">
                @if (ViewBag.Breadcrumbs is IEnumerable<KeyValuePair<string, string?>> breadcrumbs)
                {
                    <nav class="breadcrumb-nav" aria-label="Sayfa yolu">
                        @foreach (var item in breadcrumbs)
                        {
                            if (!string.IsNullOrWhiteSpace(item.Value))
                            {
                                <a href="@item.Value">@item.Key</a>
                            }
                            else
                            {
                                <span aria-current="page">@item.Key</span>
                            }
                        }
                    </nav>
                }
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success">@success</div>
                }
                @if (TempData["Error"] is string error)
                {
                    <div class="alert alert-warning">@error</div>
                }
                @RenderBody()
            </main>
        </section>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.querySelector('[data-back-button]')?.addEventListener('click', function () {
            const targetUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ReturnUrl ?? ViewData["ReturnUrl"] ?? string.Empty));
            if (targetUrl) {
                window.location.href = targetUrl;
                return;
            }

            if (window.history.length > 1) {
                window.history.back();
                return;
            }

            window.location.href = '@Url.Action("Index", "Dashboard")';
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
