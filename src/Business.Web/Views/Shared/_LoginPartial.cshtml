@using Microsoft.AspNetCore.Identity
@using Business.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav user-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item user-chip">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Hesap">
            @User.Identity?.Name
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/TwoFactorSetup">2FA Ayarları</a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link">Çıkış</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-controller="AdminRecovery" asp-action="Reset">Admin Kurtarma</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Login">Giriş</a>
    </li>
}
</ul>
