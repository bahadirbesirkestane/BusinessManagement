@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    var currentPath = Context.Request.Path.Value ?? "/";
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;
    var displayName = !string.IsNullOrWhiteSpace(currentUser?.FullName)
        ? currentUser.FullName
        : User.Identity?.Name;

    var groups = new[]
    {
        new
        {
            Title = "Dashboard",
            Items = new[]
            {
                (Label: "Genel Bakış", Url: "/Dashboard"),
                (Label: "İşlerim", Url: "/Dashboard/Workspace"),
                (Label: "Kontrol Listesi", Url: "/Dashboard/ReviewQueue"),
                (Label: "Bugünkü İşler", Url: "/Dashboard/Today"),
                (Label: "Geciken İşler", Url: "/Dashboard/Overdue"),
                (Label: "Kritik Uyarılar", Url: "/Dashboard/CriticalAlerts")
            }
        },
        new
        {
            Title = "Projeler",
            Items = new[]
            {
                (Label: "Tüm Projeler", Url: "/Projects"),
                (Label: "Tamamlanan Projeler", Url: "/Projects/Completed"),
                (Label: "Arşiv Projeler", Url: "/Projects/Archived")
            }
        },
        new
        {
            Title = "Raporlar ve Diyagramlar",
            Items = new[]
            {
                (Label: "Gantt Diyagramı", Url: "/Reports/Gantt"),
                (Label: "Kanban Diyagramı", Url: "/Reports/Kanban"),
                (Label: "Proje Planlama Gantt", Url: "/ProjectPlanning"),
                (Label: "Proje Planlama Liste", Url: "/ProjectPlanning/PlanList")
            }
        },
        new
        {
            Title = "Görevler",
            Items = new[]
            {
                (Label: "Tüm Görevler", Url: "/ProjectTasks"),
                (Label: "Tamamlanan Görevler", Url: "/ProjectTasks/Completed"),
                (Label: "Arşiv Görevler", Url: "/ProjectTasks/Archived"),
                (Label: "Bana Atananlar", Url: "/ProjectTasks/AssignedToMe"),
                (Label: "Görev Kategorileri", Url: "/TaskCategories"),
                (Label: "Görev Şablonları", Url: "/ProjectTemplates")
            }
        },
        new
        {
            Title = "Kişisel Alan",
            Items = new[]
            {
                (Label: "Kişisel Notlar", Url: "/PersonalNotes"),
                (Label: "Kişisel Görevler", Url: "/PersonalTasks")
            }
        },
        new
        {
            Title = "Siparişler",
            Items = new[]
            {
                (Label: "Tüm Siparişler", Url: "/PurchaseOrders"),
                (Label: "Teslim Edilen Siparişler", Url: "/PurchaseOrders/Delivered"),
                (Label: "Arşiv Siparişler", Url: "/PurchaseOrders/Archived"),
                (Label: "Hızlı Sipariş", Url: "/PurchaseOrders/QuickCreate"),
                (Label: "Sipariş Şablonları", Url: "/PurchaseOrderTemplates")
            }
        },
        new
        {
            Title = "Malzemeler",
            Items = new[]
            {
                (Label: "Malzeme Listesi", Url: "/Materials"),
                (Label: "Malzeme İhtiyaç Listesi", Url: "/MaterialRequests"),
                (Label: "Karşılanan İhtiyaçlar", Url: "/MaterialRequests/Fulfilled"),
                (Label: "Hızlı İhtiyaç", Url: "/MaterialRequests/QuickCreate"),
                (Label: "İhtiyaç Şablonları", Url: "/MaterialRequestTemplates"),
                (Label: "Malzeme Kategorileri", Url: "/MaterialCategories")
            }
        },
        new
        {
            Title = "Müşteriler",
            Items = new[]
            {
                (Label: "Müşteri Listesi", Url: "/Customers"),
                (Label: "Yeni Müşteri", Url: "/Customers/Create")
            }
        },
        new
        {
            Title = "Tedarikçiler",
            Items = new[]
            {
                (Label: "Tedarikçi Listesi", Url: "/Suppliers")
            }
        },
        new
        {
            Title = "Stok / Depo",
            Items = new[]
            {
                (Label: "Stok Durumu", Url: "/Stock"),
                (Label: "Stok Girişleri", Url: "/Stock/Create"),
                (Label: "Stok Çıkışları", Url: "/Stock/OutOfStock"),
                (Label: "Kritik Stoklar", Url: "/Stock/Critical")
            }
        },
        new
        {
            Title = "Maliyet",
            Items = new[]
            {
                (Label: "Proje Maliyetleri", Url: "/Costs/Projects"),
                (Label: "Sipariş Maliyetleri", Url: "/Costs/PurchaseOrders"),
                (Label: "Malzeme Giderleri", Url: "/Costs/Materials"),
                (Label: "Genel Giderler", Url: "/Costs/General")
            }
        },
        new
        {
            Title = "Faturalar",
            Items = new[]
            {
                (Label: "Fatura Listesi", Url: "/Invoices")
            }
        },
        new
        {
            Title = "Kullanıcılar",
            Items = new[]
            {
                (Label: "Kullanıcılar", Url: "/Users"),
                (Label: "Roller", Url: "/Roles"),
                (Label: "Departmanlar", Url: "/Departments")
            }
        },
        new
        {
            Title = "Ayarlar",
            Items = new[]
            {
                (Label: "Yedekleme", Url: "/Backup")
            }
        }
    };

    bool IsGroupOpen(IEnumerable<(string Label, string Url)> items)
    {
        return items.Any(item => CanSeeItem(item.Url) && currentPath.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase));
    }

    bool IsActiveLink(string url)
    {
        return currentPath.Equals(url, StringComparison.OrdinalIgnoreCase);
    }

    bool CanSeeItem(string url)
    {
        bool HasPermission(params string[] permissions)
        {
            return User.IsInRole(AppRoles.Admin) ||
                   permissions.Any(permission => User.HasClaim(AppClaimTypes.Permission, permission));
        }

        if (url.StartsWith("/Dashboard", StringComparison.OrdinalIgnoreCase))
        {
            if (url.StartsWith("/Dashboard/ReviewQueue", StringComparison.OrdinalIgnoreCase))
            {
                return User.IsInRole(AppRoles.Admin) ||
                       User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksComplete) ||
                       User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksManage) ||
                       User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
            }

            return HasPermission(AppPermissions.DashboardView);
        }

        if (url.StartsWith("/ProjectTasks", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.TasksView, AppPermissions.TasksCreate, AppPermissions.TasksUpdate, AppPermissions.TasksChangeStatus, AppPermissions.TasksComplete, AppPermissions.TasksManage);
        }

        if (url.StartsWith("/PersonalNotes", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("/PersonalTasks", StringComparison.OrdinalIgnoreCase))
        {
            return User.Identity?.IsAuthenticated == true;
        }

        if (url.StartsWith("/TaskCategories", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.ProjectsManage);
        }

        if (url.StartsWith("/ProjectTemplates", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.ProjectsView, AppPermissions.ProjectsManage);
        }

        if (url.StartsWith("/Projects", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.ProjectsView, AppPermissions.ProjectsCreate, AppPermissions.ProjectsUpdate, AppPermissions.ProjectsChangeStatus, AppPermissions.ProjectsManage);
        }

        if (url.StartsWith("/Reports/Gantt", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.ProjectsView, AppPermissions.ProjectsManage);
        }

        if (url.StartsWith("/Reports/Kanban", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.TasksView, AppPermissions.TasksManage, AppPermissions.ProjectsManage);
        }

        if (url.StartsWith("/ProjectPlanning", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.ProjectsView, AppPermissions.TasksManage, AppPermissions.ProjectsManage);
        }

        if (url.StartsWith("/PurchaseOrders", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.PurchasingView, AppPermissions.PurchasingCreate, AppPermissions.PurchasingUpdate, AppPermissions.PurchasingChangeStatus, AppPermissions.PurchasingManage);
        }

        if (url.StartsWith("/PurchaseOrderTemplates", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.PurchasingView, AppPermissions.PurchasingManage);
        }

        if (url.StartsWith("/MaterialRequests", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.MaterialRequestsView, AppPermissions.MaterialRequestsManage);
        }

        if (url.StartsWith("/MaterialRequestTemplates", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.MaterialRequestsView, AppPermissions.MaterialRequestsManage);
        }

        if (url.StartsWith("/MaterialCategories", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.MaterialsManage);
        }

        if (url.StartsWith("/Materials", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.MaterialsView, AppPermissions.MaterialsManage);
        }

        if (url.StartsWith("/Suppliers", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.SuppliersView, AppPermissions.SuppliersManage);
        }

        if (url.StartsWith("/Customers/Create", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.CustomersManage);
        }

        if (url.StartsWith("/Customers", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.CustomersView, AppPermissions.CustomersManage);
        }

        if (url.StartsWith("/Invoices", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.InvoicesView, AppPermissions.InvoicesManage);
        }

        if (url.StartsWith("/Stock/Create", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.StockManage);
        }

        if (url.StartsWith("/Stock", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.StockView, AppPermissions.StockManage);
        }

        if (url.StartsWith("/Costs", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.CostsView, AppPermissions.CostsManage);
        }

        if (url.StartsWith("/Users", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.UsersView, AppPermissions.UsersManage);
        }

        if (url.StartsWith("/Roles", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("/Departments", StringComparison.OrdinalIgnoreCase))
        {
            return HasPermission(AppPermissions.UsersManage, AppPermissions.RolesManage);
        }

        if (url.StartsWith("/Backup", StringComparison.OrdinalIgnoreCase))
        {
            return User.IsInRole(AppRoles.Admin);
        }

        return true;
    }
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="side-user">@displayName</div>
    <div class="side-nav-tools">
        <input class="form-control form-control-sm side-nav-filter"
               type="search"
               placeholder="Menüde ara"
               autocomplete="off"
               aria-label="Menüde ara"
               data-nav-filter />
    </div>

    foreach (var group in groups)
    {
        if (!group.Items.Any(item => CanSeeItem(item.Url)))
        {
            continue;
        }

        var isOpen = IsGroupOpen(group.Items);
        <details class="side-group" data-nav-group="@group.Title" @(isOpen ? "open" : "")>
            <summary>@group.Title</summary>
            <div class="side-subnav">
                @foreach (var item in group.Items)
                {
                    if (!CanSeeItem(item.Url))
                    {
                        continue;
                    }

                    <a class="@(IsActiveLink(item.Url) ? "active" : "")"
                       href="@item.Url"
                       data-nav-item="@item.Label">@item.Label</a>
                }
            </div>
        </details>
    }
}
else
{
    <a href="/">Giriş</a>
}
