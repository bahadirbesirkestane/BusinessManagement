@using Microsoft.AspNetCore.Identity
@model Business.Web.ViewModels.RecordActivityViewModel
@inject UserManager<ApplicationUser> UserManager

@functions {
    private static readonly HashSet<string> PreviewableImageExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".jpg",
        ".jpeg",
        ".png",
        ".webp",
        ".gif",
        ".bmp",
        ".svg"
    };

    private async Task<string> GetDisplayNameAsync(string? userId)
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            return "Sistem";
        }

        if (Model.UserNames.TryGetValue(userId, out var name))
        {
            return name;
        }

        var user = await UserManager.FindByIdAsync(userId);
        return user?.FullName ?? user?.Email ?? "Bilinmeyen kullanıcı";
    }

    private static bool IsPreviewableImage(string fileName, string? contentType)
    {
        if (!string.IsNullOrWhiteSpace(contentType) && contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return PreviewableImageExtensions.Contains(System.IO.Path.GetExtension(fileName));
    }
}

@{
    var previewableFiles = Model.Files
        .Where(file => IsPreviewableImage(file.OriginalFileName, file.ContentType))
        .ToList();
}

<section class="panel-block activity-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Kayıt geçmişi</p>
            <h2>Yorumlar ve Dosyalar</h2>
        </div>
    </div>

    <div class="activity-grid">
        <div>
            <form asp-controller="RecordActivity" asp-action="AddComment" method="post" class="activity-form">
                <input type="hidden" name="ownerType" value="@Model.OwnerType" />
                <input type="hidden" name="ownerId" value="@Model.OwnerId" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <textarea name="commentText" class="form-control" rows="3" placeholder="Yorum ekle"></textarea>
                <button class="btn btn-primary" type="submit">Yorum Ekle</button>
            </form>

            <div class="list-stack mt-3">
                @foreach (var comment in Model.Comments)
                {
                    var creator = await GetDisplayNameAsync(comment.CreatedByUserId);
                    <div class="list-row">
                        <span>
                            <strong>@comment.CommentText</strong>
                            <small>@creator · @comment.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                        </span>
                        @if (Model.CanDeleteComments)
                        {
                            <form asp-controller="RecordActivity" asp-action="DeleteComment" asp-route-id="@comment.Id" method="post" class="inline-form">
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button class="link-button text-danger" type="submit">Sil</button>
                            </form>
                        }
                    </div>
                }
                @if (!Model.Comments.Any())
                {
                    <p class="empty-note">Henüz yorum yok.</p>
                }
            </div>
        </div>

        <div>
            <form asp-controller="RecordActivity" asp-action="AddFile" method="post" enctype="multipart/form-data" class="activity-form" data-file-upload-form data-require-file="true">
                <input type="hidden" name="ownerType" value="@Model.OwnerType" />
                <input type="hidden" name="ownerId" value="@Model.OwnerId" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <input type="file"
                       name="files"
                       class="form-control"
                       multiple
                       data-file-upload-input
                       data-max-file-size="52428800"
                       data-max-file-size-label="50 MB"
                       accept=".pdf,.jpg,.jpeg,.png,.webp,.gif,.doc,.docx,.xls,.xlsx,.csv,.txt,.zip,.mp4,.dwg,.dxf" />
                <div class="file-upload-status" data-file-upload-status hidden>
                    <div class="file-upload-status-text" data-file-upload-text></div>
                    <div class="file-upload-progress" data-file-upload-progress hidden>
                        <div class="file-upload-progress-bar" data-file-upload-progress-bar></div>
                    </div>
                    <div class="file-upload-list" data-file-upload-list></div>
                </div>
                <input type="text" name="description" class="form-control" placeholder="Açıklama" />
                <button class="btn btn-outline-primary" type="submit">Dosya Ekle</button>
            </form>

            @if (previewableFiles.Any())
            {
                <div class="file-preview-toolbar mt-3">
                    <small class="text-muted">@previewableFiles.Count görsel tek ekranda önizlenebilir.</small>
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            data-image-preview-open-group="record-files-@Model.OwnerId"
                            data-image-preview-start-index="0">
                        Görselleri Önizle
                    </button>
                </div>
            }

            <div class="list-stack mt-3" data-image-preview-gallery="record-files-@Model.OwnerId">
                @foreach (var file in Model.Files)
                {
                    var creator = await GetDisplayNameAsync(file.CreatedByUserId);
                    <div class="list-row">
                        <span>
                            <strong><a href="@file.RelativePath" target="_blank" rel="noopener">@file.OriginalFileName</a></strong>
                            <small>@creator · @file.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · @(file.Description ?? "-")</small>
                        </span>
                        <span class="project-drive-inline-actions">
                            @if (IsPreviewableImage(file.OriginalFileName, file.ContentType))
                            {
                                var previewIndex = previewableFiles.FindIndex(x => x.Id == file.Id);
                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm"
                                        data-image-preview-open-group="record-files-@Model.OwnerId"
                                        data-image-preview-start-index="@previewIndex"
                                        data-image-preview-item
                                        data-image-preview-src="@file.RelativePath"
                                        data-image-preview-title="@file.OriginalFileName"
                                        data-image-preview-meta="@creator · @file.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")"
                                        data-image-preview-description="@(file.Description ?? "-")">
                                    Önizle
                                </button>
                            }
                            @if (Model.ShowDownloadButton)
                            {
                                <a class="btn btn-outline-primary btn-sm"
                                   asp-controller="RecordActivity"
                                   asp-action="DownloadFile"
                                   asp-route-id="@file.Id">
                                    İndir
                                </a>
                            }
                            else
                            {
                                <a class="btn btn-outline-primary btn-sm" href="@file.RelativePath" target="_blank" rel="noopener">Aç</a>
                            }

                            @if (Model.CanDeleteFiles)
                            {
                                <form asp-controller="RecordActivity" asp-action="DeleteFile" asp-route-id="@file.Id" method="post" class="inline-form">
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button class="link-button text-danger" type="submit">Sil</button>
                                </form>
                            }
                        </span>
                    </div>
                }
                @if (!Model.Files.Any())
                {
                    <p class="empty-note">Henüz dosya yok.</p>
                }
            </div>
        </div>
    </div>
</section>
