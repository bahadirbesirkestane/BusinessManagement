@{
    ViewData["Title"] = "Giriş";
}

<section class="welcome-panel">
    <div>
        <p class="section-kicker">İşletme yönetimi</p>
        <h2>Projeler, satın alma, stok ve malzeme ihtiyaçları tek panelde.</h2>
        <p>Firma içindeki roller yalnızca kendi iş akışlarına ait ekranları görür. Satın alma siparişleri takip eder, usta malzeme ihtiyacı çıkarır, proje ekibi üretim güncellemelerini yönetir.</p>
    </div>
    <div class="welcome-actions">
        <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">Giriş yap</a>
    </div>
</section>
