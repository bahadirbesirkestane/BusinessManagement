@model Material

<section class="panel-block form-panel">
    <div class="panel-heading"><div><p class="section-kicker">Malzeme kartı</p><h2>@ViewData["Title"]</h2></div></div>
    <form method="post" class="app-form">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div class="mb-3 wide"><label asp-for="Name" class="form-label">Ad</label><input asp-for="Name" class="form-control" /></div>
            <input type="hidden" asp-for="Category" value="@MaterialCategory.Other" />
            <div class="mb-3">
                <label asp-for="CategoryName" class="form-label">Kategori</label>
                <select asp-for="CategoryName" class="form-select" data-searchable-select data-search-placeholder="Kategori ara veya seç">
                    <option value="">Seçilmedi</option>
                    @foreach (var category in ViewBag.MaterialCategories)
                    {
                        <option value="@category.Name">@category.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3"><label asp-for="Type" class="form-label">Cins / tip</label><input asp-for="Type" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Grade" class="form-label">Kalite</label><input asp-for="Grade" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Surface" class="form-label">Yüzey</label><input asp-for="Surface" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Dimensions" class="form-label">Ölçü</label><input asp-for="Dimensions" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Unit" class="form-label">Birim</label><input asp-for="Unit" class="form-control" /></div>
            <div class="mb-3 wide"><label asp-for="Description" class="form-label">Açıklama</label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
            <div class="mb-3 wide"><label asp-for="Notes" class="form-label">Not</label><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div>
        </div>
        <div class="form-actions"><a class="btn btn-outline-secondary" asp-action="Index">Vazgeç</a><button class="btn btn-primary" type="submit">Kaydet</button></div>
    </form>
</section>
