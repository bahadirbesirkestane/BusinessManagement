@model IReadOnlyList<Material>
@{
    ViewData["Title"] = "Malzemeler";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Ürün kalite</p>
            <h2>Malzeme listesi</h2>
            <p class="record-count">Kayıt sayısı: <strong>@Model.Count</strong></p>
        </div>
        @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.MaterialsManage))
        {
            <a class="btn btn-primary btn-sm" asp-action="Create">Yeni malzeme</a>
        }
    </div>
    <form asp-action="Index" method="get" class="list-filter-bar">
        <div class="filter-field filter-search">
            <span class="filter-icon" aria-hidden="true">⌕</span>
            <input name="q" value="@ViewBag.FilterQ" class="form-control form-control-sm" placeholder="Malzeme, tip, kalite, ölçü ara" />
        </div>
        <select name="category" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Kategori ara veya seç">
            <option value="">Kategori</option>
            @foreach (var category in ViewBag.MaterialCategories)
            {
                <option value="@category.Name" selected="@(ViewBag.FilterCategory == category.Name)">@category.Name</option>
            }
        </select>
        <select name="type" class="form-select form-select-sm">
            <option value="">Tip</option>
            @foreach (var type in ViewBag.MaterialTypes)
            {
                <option value="@type" selected="@(ViewBag.FilterType == type)">@type</option>
            }
        </select>
        <select name="grade" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Kalite ara veya seç">
            <option value="">Kalite</option>
            @foreach (var grade in ViewBag.MaterialGrades)
            {
                <option value="@grade" selected="@(ViewBag.FilterGrade == grade)">@grade</option>
            }
        </select>
        <select name="sort" class="form-select form-select-sm">
            <option value="">Sırala: Ad</option>
            <option value="category" selected="@(ViewBag.Sort == "category")">Kategori</option>
            <option value="type" selected="@(ViewBag.Sort == "type")">Tip</option>
            <option value="grade" selected="@(ViewBag.Sort == "grade")">Kalite</option>
            <option value="created" selected="@(ViewBag.Sort == "created")">Eski kayıt</option>
        </select>
        <button class="icon-filter-button" type="submit" title="Filtrele" aria-label="Filtrele">⌕</button>
        <a class="icon-filter-button clear" asp-action="Index" title="Temizle" aria-label="Temizle">×</a>
    </form>
    @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.MaterialsManage))
    {
        <form id="bulkDeleteForm" asp-action="BulkDelete" method="post" class="bulk-action-bar">
            <button class="btn btn-outline-danger btn-sm" type="submit">Seçilenleri sil</button>
        </form>
    }
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead><tr><th></th><th>Ad</th><th>Kategori</th><th>Tip</th><th>Kalite</th><th>Yüzey</th><th></th></tr></thead>
            <tbody>
                @foreach (var material in Model)
                {
                    <tr>
                        <td>
                            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.MaterialsManage))
                            {
                                <input type="checkbox" name="ids" value="@material.Id" form="bulkDeleteForm" />
                            }
                        </td>
                        <td><strong>@material.Name</strong></td>
                        <td>@(material.CategoryName ?? material.Category.ToDisplayName())</td>
                        <td>@(material.Type ?? "-")</td>
                        <td>@(material.Grade ?? "-")</td>
                        <td>@(material.Surface ?? "-")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@material.Id">Detay</a>
                            @if (User.IsInRole(AppRoles.Admin) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.StockView) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.StockManage))
                            {
                                <span> · </span><a asp-controller="Stock" asp-action="Details" asp-route-id="@material.Id">Stok</a>
                            }
                            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.MaterialsManage))
                            {
                                <span> · </span><a asp-action="Edit" asp-route-id="@material.Id">Düzenle</a>
                                <span> · </span><a class="text-danger" asp-action="Delete" asp-route-id="@material.Id">Sil</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
