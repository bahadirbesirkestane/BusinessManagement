@model MaterialRequest
@{
    ViewData["Title"] = "Malzeme Talebi Detayı";
    var canManageRequest = User.HasClaim(AppClaimTypes.Permission, AppPermissions.MaterialRequestsManage);
    var canCreateOrder = User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingCreate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingManage);
    var requestedByName = ViewBag.RequestedByName as string;
    var createdByName = ViewBag.CreatedByName as string;
    var updatedByName = ViewBag.UpdatedByName as string;
}

<section class="panel-block">
    <div class="panel-heading">
        <div><p class="section-kicker">İhtiyaç</p><h2>@Model.RequestedItem</h2></div>
        <div class="actions-row">
            <span class="status-pill">@Model.Status.ToDisplayName()</span>
            @if (canManageRequest)
            {
                <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@Model.Id">Düzenle</a>
                <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@Model.Id">Sil</a>
            }
            @if (canCreateOrder)
            {
                <a class="btn btn-outline-secondary btn-sm" asp-controller="PurchaseOrders" asp-action="Create" asp-route-materialRequestId="@Model.Id" asp-route-returnUrl="@Context.Request.Path">Siparişe gönder</a>
            }
        </div>
    </div>
    <dl class="row">
        <dt class="col-sm-3">Proje</dt><dd class="col-sm-9">@(Model.Project?.Code ?? "Genel")</dd>
        <dt class="col-sm-3">Malzeme sınıfı</dt><dd class="col-sm-9">@(Model.Material?.Name ?? "-")</dd>
        <dt class="col-sm-3">Miktar</dt><dd class="col-sm-9">@(Model.QuantityText ?? Model.Quantity?.ToString("0.###") ?? "-")</dd>
        <dt class="col-sm-3">Kalite</dt><dd class="col-sm-9">@(Model.Quality ?? "-")</dd>
        @* <dt class="col-sm-3">Veren kişi</dt><dd class="col-sm-9">@(requestedByName ?? "-")</dd> *@
        <dt class="col-sm-3">Kaydı oluşturan</dt><dd class="col-sm-9">@(createdByName ?? "-")</dd>
        <dt class="col-sm-3">Oluşturma tarihi</dt><dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
        <dt class="col-sm-3">Son güncelleyen</dt><dd class="col-sm-9">@(updatedByName ?? "-")</dd>
        <dt class="col-sm-3">Son güncelleme</dt><dd class="col-sm-9">@(Model.UpdatedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>
        <dt class="col-sm-3">Not</dt><dd class="col-sm-9">@(Model.Notes ?? "-")</dd>
    </dl>
</section>

@if (ViewBag.Activity is Business.Web.ViewModels.RecordActivityViewModel activity)
{
    @await Html.PartialAsync("_RecordActivity", activity)
}
