@model IReadOnlyList<Business.Domain.Entities.MaterialRequest>
@{
    ViewData["Title"] = "Malzeme İhtiyaçları";
    var canManageRequest = User.HasClaim(AppClaimTypes.Permission, AppPermissions.MaterialRequestsManage);
    var canCreateOrder = User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingCreate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingManage);
    var canUseBulkSelection = canManageRequest || canCreateOrder;
    var includeFulfilled = ViewBag.IncludeFulfilled == true;
    var listAction = (string)(ViewBag.ListAction ?? "Index");
    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var defaultProjectId = ViewBag.ProjectId?.ToString();
    var requestedByNames = ViewBag.RequestedByNames as IReadOnlyDictionary<string, string> ?? new Dictionary<string, string>();
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Atölye ve proje ekibi</p>
            <h2>@(ViewBag.RequestListTitle ?? "Gerekli malzeme listesi")</h2>
            <p class="record-count">Kayıt sayısı: <strong>@Model.Count</strong></p>
        </div>
        <div class="toolbar-actions">
            @if (string.Equals(listAction, "Fulfilled", StringComparison.OrdinalIgnoreCase))
            {
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index" asp-route-projectId="@ViewBag.ProjectId">Açık liste</a>
            }
            else
            {
                <a class="btn btn-outline-secondary btn-sm" asp-action="Fulfilled" asp-route-projectId="@ViewBag.ProjectId">Karşılananlar</a>
            }
            @if (canManageRequest)
            {
                <a class="btn btn-outline-secondary btn-sm" asp-action="QuickCreate" asp-route-projectId="@ViewBag.ProjectId" asp-route-returnUrl="@currentReturnUrl">Hızlı ihtiyaç</a>
                <a class="btn btn-primary btn-sm" asp-action="Create" asp-route-projectId="@ViewBag.ProjectId" asp-route-returnUrl="@currentReturnUrl">Yeni ihtiyaç</a>
            }
        </div>
    </div>

    <form asp-action="@listAction" method="get" class="list-filter-bar list-filter-bar-wide">
        @if (ViewBag.ProjectId is not null)
        {
            <input type="hidden" name="projectId" value="@ViewBag.ProjectId" />
        }
        @if (includeFulfilled)
        {
            <input type="hidden" name="includeFulfilled" value="true" />
        }
        <div class="filter-field filter-search">
            <span class="filter-icon" aria-hidden="true">⌕</span>
            <input name="q" value="@ViewBag.FilterQ" class="form-control form-control-sm" placeholder="Malzeme, kalite, proje, veren kişi veya not ara" />
        </div>
        @if (ViewBag.ProjectId is null)
        {
            <select name="projectId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Proje ara veya seç">
                <option value="">Proje</option>
                @foreach (var project in ViewBag.Projects)
                {
                    <option value="@project.Id" selected="@(defaultProjectId == project.Id.ToString())">@project.Code - @project.Name</option>
                }
            </select>
        }
        <select name="status" class="form-select form-select-sm">
            <option value="">Durum</option>
            @foreach (MaterialRequestStatus item in Enum.GetValues<MaterialRequestStatus>())
            {
                <option value="@item" selected="@(ViewBag.FilterStatus == item)">@item.ToDisplayName()</option>
            }
        </select>
        <select name="materialId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Malzeme ara veya seç">
            <option value="">Malzeme</option>
            @foreach (var material in ViewBag.Materials)
            {
                <option value="@material.Id" selected="@(ViewBag.FilterMaterialId == material.Id)">@material.Name</option>
            }
        </select>
        <select name="requestedByUserId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Veren kişiyi ara veya seç">
            <option value="">Veren kişi</option>
            @foreach (var user in ViewBag.Users)
            {
                <option value="@user.Id" selected="@(ViewBag.FilterRequestedByUserId == user.Id)">@((user.FullName ?? user.Email ?? user.UserName ?? user.Id))</option>
            }
        </select>
        <input name="neededFrom" value="@ViewBag.FilterNeededFrom" type="date" class="form-control form-control-sm" title="Başlangıç tarihi" />
        <input name="neededTo" value="@ViewBag.FilterNeededTo" type="date" class="form-control form-control-sm" title="Bitiş tarihi" />
        <select name="sort" class="form-select form-select-sm">
            <option value="">Sırala: Yeni</option>
            <option value="item" selected="@(ViewBag.Sort == "item")">Malzeme adı</option>
            <option value="project" selected="@(ViewBag.Sort == "project")">Proje</option>
            <option value="material" selected="@(ViewBag.Sort == "material")">Tanımlı malzeme</option>
            <option value="status" selected="@(ViewBag.Sort == "status")">Durum</option>
            <option value="needed" selected="@(ViewBag.Sort == "needed")">Gerekli tarih</option>
            <option value="oldest" selected="@(ViewBag.Sort == "oldest")">Eski kayıt</option>
        </select>
        <button class="icon-filter-button" type="submit" title="Filtrele" aria-label="Filtrele">⌕</button>
        <a class="icon-filter-button clear" asp-action="@listAction" asp-route-projectId="@ViewBag.ProjectId" asp-route-includeFulfilled="@(includeFulfilled ? "true" : null)" title="Temizle" aria-label="Temizle">×</a>
    </form>

    @if (canManageRequest)
    {
        <details class="inline-quick-panel" @(Model.Any() ? null : "open")>
            <summary>Üstten hızlı ihtiyaç ekle</summary>
            <form asp-action="Create" method="post" class="quick-inline-grid mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                <input type="hidden" name="Status" value="@MaterialRequestStatus.Requested" />
                <div>
                    <label class="form-label">İstenen malzeme</label>
                    <input name="RequestedItem" class="form-control" required maxlength="420" placeholder="Ne gerekiyor?" />
                </div>
                <div>
                    <label class="form-label">Proje</label>
                    <select name="ProjectId" class="form-select" data-searchable-select data-search-placeholder="Proje ara veya seç">
                        <option value="">Genel</option>
                        @foreach (var project in ViewBag.Projects)
                        {
                            <option value="@project.Id" selected="@(defaultProjectId == project.Id.ToString())">@project.Code - @project.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Malzeme sınıfı</label>
                    <input name="MaterialNameInput" class="form-control" data-free-text-select data-target-id="InlineMaterialRequestId" data-list-id="inlineMaterialRequestOptions" placeholder="Malzeme ara veya yeni ekle" autocomplete="off" />
                    <input id="InlineMaterialRequestId" name="MaterialId" type="hidden" />
                </div>
                <div>
                    <label class="form-label">Miktar</label>
                    <input name="Quantity" type="number" step="0.001" class="form-control" />
                </div>
                <div>
                    <label class="form-label">Birim</label>
                    <input name="Unit" class="form-control" maxlength="40" placeholder="Adet, kg, metre" />
                </div>
                <div>
                    <label class="form-label">Miktar metni</label>
                    <input name="QuantityText" class="form-control" maxlength="80" placeholder="Örn. 12 adet" />
                </div>
                <div>
                    <label class="form-label">Kalite</label>
                    <input name="Quality" class="form-control" maxlength="120" />
                </div>
                <div>
                    <label class="form-label">Gerekli tarih</label>
                    <input name="NeededBy" type="date" class="form-control" value="@DateTime.Today.AddDays(3).ToString("yyyy-MM-dd")" />
                </div>
                <div class="quick-inline-grid-wide">
                    <label class="form-label">Not</label>
                    <input name="Notes" class="form-control" maxlength="2000" />
                </div>
                <div class="quick-inline-actions">
                    <button class="btn btn-primary" type="submit">Hızlı kaydet</button>
                </div>
            </form>
        </details>
    }

    @if (canUseBulkSelection)
    {
        <form id="bulkRequestSelectionForm" asp-action="BulkDelete" method="post" class="bulk-action-bar smart-bulk-bar" data-bulk-panel="bulkRequestSelectionForm" hidden>
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
            <span class="bulk-selection-count" data-bulk-count="bulkRequestSelectionForm">0 kayıt seçildi</span>
            <div class="bulk-bar-actions">
                <button class="btn btn-outline-secondary btn-sm" type="button" data-bulk-clear="bulkRequestSelectionForm">Seçimi temizle</button>
                @if (canManageRequest)
                {
                    <select name="status" class="form-select form-select-sm" aria-label="Toplu ihtiyaç durumu">
                        @foreach (MaterialRequestStatus item in Enum.GetValues<MaterialRequestStatus>())
                        {
                            <option value="@item">@item.ToDisplayName()</option>
                        }
                    </select>
                    <button class="btn btn-outline-secondary btn-sm" type="submit" formaction="@Url.Action("BulkUpdateStatus")">Durumu güncelle</button>
                }
                @if (canCreateOrder)
                {
                    <button class="btn btn-outline-primary btn-sm" type="submit" formaction="@Url.Action("TransferToQuickOrder")" data-bulk-submit="bulkRequestSelectionForm">Seçilenleri siparişe aktar</button>
                }
                @if (canManageRequest)
                {
                    <button class="btn btn-outline-danger btn-sm" type="submit" data-bulk-submit="bulkRequestSelectionForm">Seçilenleri sil</button>
                }
            </div>
        </form>
    }

    @if (!Model.Any())
    {
        <div class="empty-note empty-note-empty-state">
            <div>
                <strong>Uygun ihtiyaç kaydı bulunamadı.</strong>
                <span>Filtreleri temizleyin veya yeni bir ihtiyaç kaydı ekleyin.</span>
            </div>
            @if (canManageRequest)
            {
                <a class="btn btn-primary btn-sm" asp-action="Create" asp-route-projectId="@ViewBag.ProjectId" asp-route-returnUrl="@currentReturnUrl">Yeni ihtiyaç oluştur</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive table-responsive-menu">
            <table class="table app-table align-middle">
                <thead>
                    <tr>
                        <th>Malzeme</th>
                        @if (canUseBulkSelection)
                        {
                            <th class="bulk-check-cell">
                                <input type="checkbox" data-bulk-toggle="bulkRequestSelectionForm" aria-label="Tüm ihtiyaç kayıtlarını seç" />
                            </th>
                        }
                        <th>Proje</th>
                        <th>Miktar</th>
                        <th>Kalite</th>
                        <th>Veren kişi</th>
                        <th>Gerekli tarih</th>
                        <th>Durum</th>
                        <th>Not</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        var returnUrl = currentReturnUrl;
                        var quantityDisplay = request.QuantityText
                            ?? (request.Quantity.HasValue
                                ? string.IsNullOrWhiteSpace(request.Unit)
                                    ? request.Quantity.Value.ToString("0.###")
                                    : $"{request.Quantity.Value:0.###} {request.Unit}"
                                : "-");
                        var requestedByName = !string.IsNullOrWhiteSpace(request.RequestedByUserId) && requestedByNames.TryGetValue(request.RequestedByUserId, out var resolvedRequestedByName)
                            ? resolvedRequestedByName
                            : "-";
                        var previewDescription = !string.IsNullOrWhiteSpace(request.Notes)
                            ? request.Notes
                            : "Bu ihtiyaç kaydı için ek not girilmemiş. Detay sayfasından dosyaları ve yorumları inceleyebilirsiniz.";
                        <tr class="status-row status-@request.Status.ToString().ToLowerInvariant()"
                            data-row-link="@Url.Action("Details", new { id = request.Id })"
                            data-preview-group="material-requests-list"
                            data-preview-title="@request.RequestedItem"
                            data-preview-subtitle="Proje: @(request.Project?.Code ?? "Genel") | Tanımlı malzeme: @(request.Material?.Name ?? "Belirtilmedi")"
                            data-preview-meta="Veren kişi: @requestedByName | Gerekli tarih: @request.NeededBy.ToString("dd.MM.yyyy") | Kalite: @(request.Quality ?? "Belirtilmedi")"
                            data-preview-description="@previewDescription"
                            data-preview-status="@request.Status.ToDisplayName()">
                            <td>
                                <strong>@request.RequestedItem</strong>
                                <small class="d-block text-muted table-note-clamp">@request.Material?.Name</small>
                            </td>
                            @if (canUseBulkSelection)
                            {
                                <td><input type="checkbox" name="ids" value="@request.Id" form="bulkRequestSelectionForm" /></td>
                            }
                            <td>@(request.Project?.Code ?? "Genel")</td>
                            <td>@quantityDisplay</td>
                            <td>@(request.Quality ?? "-")</td>
                            <td>@requestedByName</td>
                            <td>@request.NeededBy.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (canManageRequest)
                                {
                                    <form asp-action="UpdateStatus" method="post" class="inline-status-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <select name="status" class="status-select status-@request.Status.ToString().ToLowerInvariant()" onchange="this.form.submit()" aria-label="İhtiyaç durumu">
                                            @foreach (MaterialRequestStatus item in Enum.GetValues<MaterialRequestStatus>())
                                            {
                                                <option value="@item" selected="@(request.Status == item)">@item.ToDisplayName()</option>
                                            }
                                        </select>
                                    </form>
                                }
                                else
                                {
                                    <span class="status-pill status-@request.Status.ToString().ToLowerInvariant()">@request.Status.ToDisplayName()</span>
                                }
                            </td>
                            <td>@(request.Notes ?? "-")</td>
                            <td class="text-end action-cell">
                                <div class="action-shell">
                                    <button class="preview-trigger" type="button" data-preview-trigger title="Hızlı önizleme" aria-label="Hızlı önizleme">i</button>
                                    <details class="action-menu">
                                        <summary aria-label="İhtiyaç işlemleri">...</summary>
                                        <div class="action-menu-list">
                                            <a asp-action="Details" asp-route-id="@request.Id">Detay</a>
                                            @if (canCreateOrder)
                                            {
                                                <a asp-controller="PurchaseOrders" asp-action="Create" asp-route-materialRequestId="@request.Id" asp-route-returnUrl="@returnUrl">Siparişe gönder</a>
                                            }
                                            @if (canManageRequest)
                                            {
                                                <form asp-action="Repeat" asp-route-id="@request.Id" method="post" class="inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button class="link-button" type="submit">İhtiyacı tekrarla</button>
                                                </form>
                                                <a asp-action="Edit" asp-route-id="@request.Id" asp-route-returnUrl="@returnUrl">Düzenle</a>
                                                <a class="text-danger" asp-action="Delete" asp-route-id="@request.Id">Sil</a>
                                            }
                                        </div>
                                    </details>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<div class="compact-preview-popover" data-compact-preview hidden>
    <span class="list-preview-status" data-preview-status></span>
    <h3 data-preview-title></h3>
    <p class="list-preview-subtitle" data-preview-subtitle></p>
    <p class="list-preview-meta" data-preview-meta></p>
    <p class="list-preview-description" data-preview-description></p>
</div>

<datalist id="inlineMaterialRequestOptions">
    @foreach (var material in ViewBag.Materials)
    {
        <option value="@material.Name" data-id="@material.Id"></option>
    }
</datalist>
