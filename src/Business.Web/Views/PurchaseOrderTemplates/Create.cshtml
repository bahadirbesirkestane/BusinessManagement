@model PurchaseOrderTemplateFormViewModel
@{
    ViewData["Title"] = "Yeni Sipariş Şablonu";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Sipariş şablonları</p>
            <h2>Yeni şablon oluştur</h2>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Listeye dön</a>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <partial name="_TemplateForm" model="Model" />
        <div class="d-flex justify-content-end gap-2 mt-3">
            <a class="btn btn-outline-secondary" asp-action="Index">Vazgeç</a>
            <button type="submit" class="btn btn-primary">Kaydet</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
