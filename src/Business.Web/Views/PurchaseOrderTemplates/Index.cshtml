@model IReadOnlyList<PurchaseOrderTemplateListItemViewModel>
@{
    ViewData["Title"] = "Siparis Sablonlari";
    var canManageTemplates = User.IsInRole(AppRoles.Admin) ||
        User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingManage);
}

<section class="diagram-hero">
    <div>
        <p class="section-kicker">Satin alma</p>
        <h2>Siparis sablonlari</h2>
        <p>Tekrar eden satin alma kalemlerini standartlastirmak icin siparis sablonlarini yonetin.</p>
    </div>
    <div class="diagram-summary-grid">
        <div>
            <span>Toplam sablon</span>
            <strong>@Model.Count</strong>
        </div>
        <div>
            <span>Aktif sablon</span>
            <strong>@Model.Count(x => x.IsActive)</strong>
        </div>
        <div>
            <span>Toplam satir</span>
            <strong>@Model.Sum(x => x.LineCount)</strong>
        </div>
    </div>
</section>

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Sablon listesi</p>
            <h2>Kayitli siparis sablonlari</h2>
        </div>
        @if (canManageTemplates)
        {
            <a class="btn btn-primary btn-sm" asp-action="Create">Yeni sablon</a>
        }
    </div>

    @if (!Model.Any())
    {
        <p class="empty-note">Henuz siparis sablonu bulunmuyor.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Sablon</th>
                        <th>Kapsam</th>
                        <th>Tedarikci</th>
                        <th>Satir</th>
                        <th>Durum</th>
                        <th class="text-end">Islemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(item.Code))
                                {
                                    <div class="text-muted small">@item.Code</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <div class="text-muted small">@item.Description</div>
                                }
                            </td>
                            <td>@item.ScopeText</td>
                            <td>@(item.SupplierName ?? "-")</td>
                            <td>@item.LineCount</td>
                            <td>
                                <span class="status-pill @(item.IsActive ? "status-done" : "status-waiting")">
                                    @(item.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm" asp-action="Details" asp-route-id="@item.Id">Detay</a>
                                @if (canManageTemplates)
                                {
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Duzenle</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-outline-danger btn-sm" type="submit" onclick="return confirm('Bu siparis sablonu ve tum satirlari silinsin mi?');">Sil</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
