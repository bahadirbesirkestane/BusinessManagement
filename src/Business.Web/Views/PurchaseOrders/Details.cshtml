@model PurchaseOrder
@{
    ViewData["Title"] = "Sipariş Detayı";
    var returnUrl = ViewBag.ReturnUrl as string ?? $"{Context.Request.Path}{Context.Request.QueryString}";
    var canDeleteOrder = User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingDelete) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingManage);
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">@Model.OrderNumber</p>
            <h2>@Model.Content</h2>
        </div>
        <div class="project-header-actions">
            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingChangeStatus) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingManage))
            {
                <form asp-action="UpdateStatus" method="post" class="inline-status-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <select name="status" class="status-select status-@Model.Status.ToString().ToLowerInvariant()" onchange="this.form.submit()" aria-label="Sipariş durumu">
                        @foreach (PurchaseOrderStatus status in Enum.GetValues<PurchaseOrderStatus>())
                        {
                            <option value="@status" selected="@(Model.Status == status)">@status.ToDisplayName()</option>
                        }
                    </select>
                </form>
            }
            else
            {
                <span class="status-pill status-@Model.Status.ToString().ToLowerInvariant()">@Model.Status.ToDisplayName()</span>
            }
            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingCreate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingManage))
            {
                <form asp-action="Repeat" method="post" class="inline-status-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button class="btn btn-outline-secondary btn-sm" type="submit">Siparişi tekrarla</button>
                </form>
            }
            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingUpdate) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingManage))
            {
                <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl">Düzenle</a>
            }
            @if (canDeleteOrder)
            {
                <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl">Sil</a>
            }
        </div>
    </div>
    <dl class="row">
        <dt class="col-sm-3">Proje</dt><dd class="col-sm-9">@(Model.Project?.Code ?? "Genel")</dd>
        <dt class="col-sm-3">Tedarikçi</dt><dd class="col-sm-9">@(Model.Supplier?.Name ?? "-")</dd>
        <dt class="col-sm-3">Siparişi veren</dt><dd class="col-sm-9">@(ViewBag.RequesterName ?? "-")</dd>
        <dt class="col-sm-3">Sipariş tarihi</dt><dd class="col-sm-9">@(Model.OrderDate?.ToString("dd.MM.yyyy") ?? "-")</dd>
        <dt class="col-sm-3">Beklenen varış</dt><dd class="col-sm-9">@(Model.ExpectedArrivalDate?.ToString("dd.MM.yyyy") ?? "-")</dd>
        <dt class="col-sm-3">Varış tarihi</dt><dd class="col-sm-9">@(Model.ArrivalDate?.ToString("dd.MM.yyyy") ?? "-")</dd>
        <dt class="col-sm-3">Malzeme</dt><dd class="col-sm-9">@(Model.Material?.Name ?? "-")</dd>
        <dt class="col-sm-3">Miktar</dt><dd class="col-sm-9">@(Model.QuantityText ?? Model.Quantity?.ToString("0.###") ?? "-")</dd>
        <dt class="col-sm-3">Kalite</dt><dd class="col-sm-9">@(Model.Quality ?? "-")</dd>
        <dt class="col-sm-3">Vade</dt><dd class="col-sm-9">@(Model.PaymentTerm ?? "-")</dd>
        <dt class="col-sm-3">Birim fiyat</dt><dd class="col-sm-9">@(Model.UnitPriceText ?? Model.UnitPrice?.ToString("N2") ?? "-")</dd>
        <dt class="col-sm-3">Sipariş tutarı</dt><dd class="col-sm-9">@((Model.OrderTotal ?? ((Model.UnitPrice ?? 0) * (Model.Quantity ?? 0))).ToString("N2")) @Model.Currency</dd>
        <dt class="col-sm-3">Not</dt><dd class="col-sm-9">@(Model.Notes ?? "-")</dd>
    </dl>
</section>

@if (ViewBag.Activity is Business.Web.ViewModels.RecordActivityViewModel activity)
{
    @await Html.PartialAsync("_RecordActivity", activity)
}
