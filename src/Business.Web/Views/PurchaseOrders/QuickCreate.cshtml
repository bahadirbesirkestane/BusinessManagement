@model QuickPurchaseOrderViewModel
@{
    ViewData["Title"] = "Hızlı Sipariş Ekle";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<section class="panel-block form-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Satın alma</p>
            <h2>Hızlı sipariş ekleme</h2>
        </div>
        @if (!string.IsNullOrWhiteSpace(returnUrl))
        {
            <a class="btn btn-outline-secondary btn-sm" href="@returnUrl">Geri dön</a>
        }
        else
        {
            <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Sipariş listesi</a>
        }
    </div>

    @if (ViewBag.Templates is IEnumerable<dynamic> templates && templates.Any())
    {
        <form asp-action="QuickCreate" method="get" class="diagram-filter-bar mb-3">
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <select name="projectId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Proje ara veya seç">
                <option value="">Genel sipariş</option>
                @foreach (var project in ViewBag.Projects)
                {
                    <option value="@project.Id" selected="@(Model.ProjectId == project.Id)">@project.Code - @project.Name</option>
                }
            </select>
            <select name="templateId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Şablon ara veya seç">
                <option value="">Sipariş şablonu seçin</option>
                @foreach (var template in templates)
                {
                    <option value="@template.Id" selected="@(Model.TemplateId == template.Id)">@template.Text</option>
                }
            </select>
            <button class="btn btn-outline-primary btn-sm" type="submit">Şablonu yükle</button>
            <a class="btn btn-outline-secondary btn-sm" asp-controller="PurchaseOrderTemplates" asp-action="Index">Şablonlar</a>
        </form>
    }

    <form asp-action="QuickCreate" method="post" class="app-form quick-order-form" data-quick-order-form novalidate>
        @Html.AntiForgeryToken()
        <input asp-for="TemplateId" type="hidden" />
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="quick-order-context">
            <div class="mb-3">
                <label asp-for="ProjectId" class="form-label">Proje bağı</label>
                <select asp-for="ProjectId" class="form-select" data-project-select data-searchable-select data-search-placeholder="Proje ara veya seç">
                    <option value="">Genel sipariş</option>
                    @foreach (var project in ViewBag.Projects)
                    {
                        <option value="@project.Id">@project.Code - @project.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label">Durum</label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<PurchaseOrderStatus>()" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="OrderDate" class="form-label">Sipariş tarihi</label>
                <input asp-for="OrderDate" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="ExpectedArrivalDate" class="form-label">Beklenen varış</label>
                <input asp-for="ExpectedArrivalDate" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="PaymentTerm" class="form-label">Vade</label>
                <input asp-for="PaymentTerm" class="form-control" />
            </div>
        </div>

        <input asp-for="Scope" type="hidden" data-scope-input />

        <div class="quick-order-sheet-wrap quick-order-sheet-wrap-tall">
            <table class="quick-order-sheet">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Sipariş içeriği</th>
                        <th>Tedarikçi</th>
                        <th>Malzeme</th>
                        <th>Adet</th>
                        <th>Birim</th>
                        <th>Kalite</th>
                        <th>Birim fiyat</th>
                        <th>Sipariş tutarı</th>
                        <th>Not</th>
                    </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.Lines.Count; i++)
                {
                    <tr class="quick-order-row" data-row-index="@i">
                        <td class="row-number">@(i + 1)</td>
                        <td><input asp-for="Lines[i].Content" class="form-control form-control-sm quick-cell main-cell" autocomplete="off" /></td>
                        <td>
                            <input asp-for="Lines[i].SupplierName" class="form-control form-control-sm quick-cell" data-free-text-select data-target-id="Lines_@(i)__SupplierId" data-list-id="quickCreateSupplierOptions" placeholder="Tedarikçi ara veya yeni ekle" autocomplete="off" />
                            <input asp-for="Lines[i].SupplierId" type="hidden" />
                        </td>
                        <td>
                            <input asp-for="Lines[i].MaterialName" class="form-control form-control-sm quick-cell" data-free-text-select data-target-id="Lines_@(i)__MaterialId" data-list-id="quickCreateMaterialOptions" placeholder="Malzeme ara veya yeni ekle" autocomplete="off" />
                            <input asp-for="Lines[i].MaterialId" type="hidden" />
                        </td>
                        <td><input asp-for="Lines[i].Quantity" type="text" inputmode="decimal" class="form-control form-control-sm quick-cell quantity-cell" /></td>
                        <td><input asp-for="Lines[i].Unit" class="form-control form-control-sm quick-cell" /></td>
                        <td><input asp-for="Lines[i].Quality" class="form-control form-control-sm quick-cell" /></td>
                        <td><input asp-for="Lines[i].UnitPrice" type="text" inputmode="decimal" class="form-control form-control-sm quick-cell unit-price-cell" /></td>
                        <td><input asp-for="Lines[i].OrderTotal" type="text" inputmode="decimal" class="form-control form-control-sm quick-cell total-cell" /></td>
                        <td><input asp-for="Lines[i].Notes" class="form-control form-control-sm quick-cell" /></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="form-actions">
            @if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                <a class="btn btn-outline-secondary" href="@returnUrl">Vazgeç</a>
            }
            else
            {
                <a class="btn btn-outline-secondary" asp-action="Index">Vazgeç</a>
            }
            <button class="btn btn-primary" type="submit">Siparişleri Kaydet</button>
        </div>
    </form>
</section>

<datalist id="quickCreateSupplierOptions">
    @foreach (var supplier in ViewBag.Suppliers)
    {
        <option value="@supplier.Name" data-id="@supplier.Id"></option>
    }
</datalist>

<datalist id="quickCreateMaterialOptions">
    @foreach (var material in ViewBag.Materials)
    {
        <option value="@material.Name" data-id="@material.Id"></option>
    }
</datalist>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.querySelector('[data-quick-order-form]');
            if (!form) return;

            const tbody = form.querySelector('tbody');
            const projectSelect = form.querySelector('[data-project-select]');
            const scopeInput = form.querySelector('[data-scope-input]');

            const updateScope = () => {
                if (scopeInput) {
                    scopeInput.value = projectSelect?.value ? 'Project' : 'General';
                }
            };

            const parseNumber = (value) => {
                if (!value) {
                    return NaN;
                }

                return Number(String(value).replace(',', '.'));
            };

            const calculateTotal = (row) => {
                const quantity = parseNumber(row.querySelector('.quantity-cell')?.value);
                const unitPrice = parseNumber(row.querySelector('.unit-price-cell')?.value);
                const total = row.querySelector('.total-cell');

                if (!total) {
                    return;
                }

                if (Number.isFinite(quantity) && Number.isFinite(unitPrice)) {
                    total.value = (quantity * unitPrice).toFixed(2);
                    return;
                }

                total.value = '';
            };

            const addRow = () => {
                const rows = [...tbody.querySelectorAll('tr')];
                const last = rows[rows.length - 1];
                const nextIndex = rows.length;
                const row = last.cloneNode(true);

                row.dataset.rowIndex = nextIndex;
                row.querySelector('.row-number').textContent = nextIndex + 1;
                row.querySelectorAll('input, select').forEach(input => {
                    input.name = input.name.replace(/Lines\[\d+\]/, `Lines[${nextIndex}]`);
                    input.id = input.id.replace(/Lines_\d+__/, `Lines_${nextIndex}__`);

                    if (input.dataset && input.dataset.targetId) {
                        input.dataset.targetId = input.dataset.targetId.replace(/Lines_\d+__/, `Lines_${nextIndex}__`);
                    }

                    if (input.tagName === 'SELECT') {
                        input.selectedIndex = 0;
                    } else {
                        input.value = '';
                    }
                });

                tbody.appendChild(row);
                if (window.initFreeTextLookups) {
                    window.initFreeTextLookups(row);
                }
                return row;
            };

            const activateNextRow = (row) => {
                let next = row.nextElementSibling;
                if (!next) {
                    next = addRow();
                }

                next.querySelector('.main-cell')?.focus();
            };

            form.addEventListener('keydown', event => {
                if (event.key !== 'Enter') return;

                const cell = event.target.closest('.quick-cell');
                if (!cell) return;

                event.preventDefault();

                const row = event.target.closest('tr');
                if (event.target.classList.contains('main-cell') && event.target.value.trim()) {
                    activateNextRow(row);
                    return;
                }

                const cells = [...row.querySelectorAll('.quick-cell')];
                const index = cells.indexOf(event.target);
                const nextCell = cells[index + 1];

                if (nextCell) {
                    nextCell.focus();
                } else {
                    activateNextRow(row);
                }
            });

            form.addEventListener('input', event => {
                const row = event.target.closest('tr');
                if (!row) return;

                if (event.target.classList.contains('quantity-cell') || event.target.classList.contains('unit-price-cell')) {
                    calculateTotal(row);
                }
            });

            projectSelect?.addEventListener('change', updateScope);
            updateScope();
        })();
    </script>
}
