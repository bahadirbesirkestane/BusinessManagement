@model ProjectTemplateFormViewModel
@{
    ViewData["Title"] = "Gorev Sablonu Duzenle";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Gorev sablonlari</p>
            <h2>Sablonu duzenle</h2>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Details" asp-route-id="@Model.Id">Detaya don</a>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <partial name="_TemplateForm" model="Model" />
        <div class="d-flex justify-content-end gap-2 mt-3">
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Vazgec</a>
            <button type="submit" class="btn btn-primary">Guncelle</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
