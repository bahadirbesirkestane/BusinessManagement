@model ProjectPlanningIndexViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Proje Planlama Gantt";
    var frappeTasks = Model.GanttTasks.Select(x => new
    {
        id = x.Id,
        name = x.Name,
        start = x.Start,
        end = x.End,
        progress = x.Progress,
        dependencies = x.Dependencies,
        custom_class = x.CustomClass,
        url = x.Url
    });
}

<link rel="stylesheet" href="~/lib/frappe-gantt/frappe-gantt.css" asp-append-version="true" />

<section class="diagram-hero">
    <div>
        <p class="section-kicker">Raporlar ve diyagramlar</p>
        <h2>Proje planlama görünümü</h2>
        <p>Seçilen projenin görevleri hiyerarşik ağaç yapısında listelenir; tarihli görevler sağdaki Gantt çizelgesinde izlenir.</p>
    </div>
    <div class="diagram-summary-grid">
        <div>
            <span>Proje seçeneği</span>
            <strong>@Model.Projects.Count</strong>
        </div>
        <div>
            <span>Görev satırı</span>
            <strong>@Model.Tasks.Count</strong>
        </div>
        <div>
            <span>Gantt görevi</span>
            <strong>@Model.GanttTasks.Count</strong>
        </div>
    </div>
</section>

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Proje bazlı planlama</p>
            <h2>Gantt 2 görev ağacı</h2>
        </div>
        <div class="toolbar-actions">
            <a class="btn btn-outline-primary btn-sm" asp-controller="Reports" asp-action="Gantt">Mevcut Gantt</a>
            <a class="btn btn-outline-secondary btn-sm" asp-controller="Reports" asp-action="Kanban">Kanban</a>
        </div>
    </div>

    <form asp-action="Index" method="get" class="diagram-filter-bar">
        <select name="projectId" class="form-select form-select-sm">
            <option value="">Proje seçin</option>
            @foreach (var project in Model.Projects)
            {
                <option value="@project.Id" selected="@(Model.ProjectId == project.Id)">@project.Text</option>
            }
        </select>
        <button class="btn btn-primary btn-sm" type="submit">Uygula</button>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Temizle</a>
    </form>

    @if (!Model.ProjectId.HasValue)
    {
        <p class="empty-note">Planlama görünümünü açmak için üst alandan bir proje seçin.</p>
    }
    else if (Model.SelectedProjectText is null)
    {
        <p class="empty-note">Seçilen proje bulunamadı veya iptal edilmiş olabilir.</p>
    }
    else
    {
        <div class="planning-context">
            <span>Seçili proje</span>
            <strong>@Model.SelectedProjectText</strong>
        </div>

        <div class="planning-shell">
            <section class="planning-tree">
                <header>
                    <div>
                        <span>Görev Ağacı</span>
                        <strong>@Model.Tasks.Count görev</strong>
                    </div>
                </header>

                @if (!Model.Tasks.Any())
                {
                    <p class="planning-empty">Bu proje için plan görevi bulunamadı.</p>
                }
                else
                {
                    var scheduledTasks = Model.Tasks.Where(x => x.StartDate.HasValue && x.DueDate.HasValue).ToList();
                    var unscheduledTasks = Model.Tasks.Where(x => !x.StartDate.HasValue || !x.DueDate.HasValue).ToList();

                    <div class="planning-tree-list">
                        @foreach (var task in scheduledTasks)
                        {
                            <a class="planning-tree-row" style="--task-level:@task.OutlineLevel" asp-controller="ProjectTasks" asp-action="Details" asp-route-id="@task.Id">
                                <span class="planning-tree-title">
                                    @if (task.HasChildren)
                                    {
                                        <span class="planning-tree-marker">&rsaquo;</span>
                                    }
                                    else
                                    {
                                        <span class="planning-tree-marker"></span>
                                    }
                                    <strong>@task.Title</strong>
                                    @if (task.IsMilestone)
                                    {
                                        <em>Kilometre taşı</em>
                                    }
                                </span>
                            </a>
                        }
                    </div>

                    @if (unscheduledTasks.Any())
                    {
                        <div class="planning-unscheduled">
                            <span>Tarihsiz görevler</span>
                            @foreach (var task in unscheduledTasks)
                            {
                                <a class="planning-unscheduled-row" style="--task-level:@task.OutlineLevel" asp-controller="ProjectTasks" asp-action="Details" asp-route-id="@task.Id">
                                    <span class="planning-tree-title">
                                        @if (task.HasChildren)
                                        {
                                            <span class="planning-tree-marker">&rsaquo;</span>
                                        }
                                        else
                                        {
                                            <span class="planning-tree-marker"></span>
                                        }
                                        <strong>@task.Title</strong>
                                    </span>
                                </a>
                            }
                        </div>
                    }
                }
            </section>

            <section class="planning-timeline">
                <header>
                    <div>
                        <span>Zaman Çizelgesi</span>
                        <strong>Frappe Gantt</strong>
                    </div>
                    @if (Model.GanttTasks.Any())
                    {
                        <div class="planning-gantt-modes" aria-label="Gantt görünüm seçenekleri">
                            <button class="active" type="button" data-gantt-view="Day">Gün</button>
                            <button type="button" data-gantt-view="Week">Hafta</button>
                            <button type="button" data-gantt-view="Month">Ay</button>
                        </div>
                    }
                </header>

                @if (!Model.Tasks.Any())
                {
                    <p class="planning-empty">Zaman çizelgesi oluşturmak için bu projeye başlangıç ve termin tarihleri olan görevler eklenmeli.</p>
                }
                else if (!Model.GanttTasks.Any())
                {
                    <p class="planning-empty">Bu projedeki görevler ağaçta görünüyor; Gantt çizelgesinde göstermek için görevlerde başlangıç ve termin tarihi olmalı.</p>
                }
                else
                {
                    <div class="planning-gantt-shell">
                        <svg id="project_planning_gantt"></svg>
                        <p id="project_planning_gantt_error" class="planning-empty d-none">Gantt çizelgesi yüklenemedi. Local Frappe Gantt dosyalarının yayınlandığını kontrol edin.</p>
                    </div>
                }
            </section>
        </div>
    }
</section>

@section Scripts {
    @if (Model.GanttTasks.Any())
    {
        <script src="~/lib/frappe-gantt/frappe-gantt.umd.js" asp-append-version="true"></script>
        <script>
            const projectPlanningTasks = @Html.Raw(JsonSerializer.Serialize(frappeTasks));
            const projectPlanningTaskUrls = Object.fromEntries(projectPlanningTasks.map(function (task) {
                return [task.id, task.url];
            }));

            (function () {
                const chartElement = document.getElementById('project_planning_gantt');
                const errorElement = document.getElementById('project_planning_gantt_error');
                const modeButtons = Array.from(document.querySelectorAll('[data-gantt-view]'));
                let gantt = null;

                function showError() {
                    if (errorElement) {
                        errorElement.classList.remove('d-none');
                    }
                }

                function setActiveMode(mode) {
                    modeButtons.forEach(function (button) {
                        button.classList.toggle('active', button.dataset.ganttView === mode);
                    });
                }

                function changeViewMode(mode) {
                    if (!gantt) {
                        return;
                    }

                    if (typeof gantt.change_view_mode === 'function') {
                        gantt.change_view_mode(mode);
                    } else if (typeof gantt.update_options === 'function') {
                        gantt.update_options({ view_mode: mode });
                    }

                    setActiveMode(mode);
                }

                window.addEventListener('load', function () {
                    if (!chartElement || typeof Gantt === 'undefined') {
                        showError();
                        return;
                    }

                    try {
                        gantt = new Gantt('#project_planning_gantt', projectPlanningTasks, {
                            view_mode: 'Day',
                            view_modes: ['Day', 'Week', 'Month'],
                            language: 'tr',
                            date_format: 'YYYY-MM-DD',
                            bar_height: 24,
                            padding: 18,
                            popup_trigger: 'mouseover',
                            on_click: function (task) {
                                const url = task ? (task.url || projectPlanningTaskUrls[task.id]) : null;
                                if (url) {
                                    window.location.href = url;
                                }
                            }
                        });

                        modeButtons.forEach(function (button) {
                            button.addEventListener('click', function () {
                                changeViewMode(button.dataset.ganttView);
                            });
                        });
                    } catch {
                        showError();
                    }
                });

                window.setTimeout(function () {
                    if (chartElement && chartElement.children.length === 0) {
                        showError();
                    }
                }, 5000);
            })();
        </script>
    }
}
