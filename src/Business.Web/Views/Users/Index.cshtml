@model IReadOnlyList<Business.Web.ViewModels.UserListItemViewModel>
@{
    ViewData["Title"] = "Kullanıcılar";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Kullanıcılar ve Yetkiler</p>
            <h2>Kullanıcılar</h2>
        </div>
        <a class="btn btn-primary" asp-action="Create">Kullanıcı Ekle</a>
    </div>
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Roller</th>
                    <th>Durum</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model)
            {
                var isAdmin = user.RolesText.Split(", ").Contains(AppRoles.Admin);
                <tr class="@(user.IsActive ? "" : "row-muted")">
                    <td><strong>@(user.FullName ?? "-")</strong></td>
                    <td>@user.Email</td>
                    <td>@user.RolesText</td>
                    <td><span class="status-pill @(user.IsActive ? "status-success" : "status-danger")">@(user.IsActive ? "Aktif" : "Pasif")</span></td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@user.Id">Düzenle</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="ResetPassword" asp-route-id="@user.Id">Şifre Sıfırla</a>
                        @if (User.IsInRole(AppRoles.Admin))
                        {
                            @if (isAdmin)
                            {
                                <a class="btn btn-sm btn-outline-secondary" asp-action="GenerateRecoveryCodes" asp-route-id="@user.Id">Kurtarma Kodu</a>
                            }
                            <form class="inline-form" asp-action="Delete" asp-route-id="@user.Id" method="post">
                                <button class="btn btn-sm btn-outline-danger" type="submit">Sil</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
