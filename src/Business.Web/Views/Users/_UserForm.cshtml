@model Business.Web.ViewModels.UserFormViewModel

<section class="panel-block form-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Kullanıcılar ve Yetkiler</p>
            <h2>@ViewData["Title"]</h2>
        </div>
    </div>
    <form method="post" class="app-form">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="DepartmentId" class="form-label"></label>
                <select asp-for="DepartmentId" class="form-select">
                    <option value="">Departman seçilmedi</option>
                    @foreach (var department in ViewBag.Departments)
                    {
                        <option value="@department.Id">@department.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3 wide">
                <label class="form-label">Roller</label>
                <div class="check-grid">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <label class="check-card">
                            <input type="checkbox" name="SelectedRoles" value="@role" checked="@Model.SelectedRoles.Contains(role)" />
                            <span>@role</span>
                        </label>
                    }
                </div>
            </div>
            <details class="mb-3 wide permission-toggle">
                <summary>Kullanıcıya Özel Ek Yetkiler</summary>
                @foreach (var group in AppPermissions.All.GroupBy(x => x.Group))
                {
                    <div class="permission-group">
                        <h3>@group.Key</h3>
                        <div class="check-grid">
                            @foreach (var permission in group)
                            {
                                <label class="check-card">
                                    <input type="checkbox" name="SelectedPermissions" value="@permission.Value" checked="@Model.SelectedPermissions.Contains(permission.Value)" />
                                    <span>@permission.Name</span>
                                </label>
                            }
                        </div>
                    </div>
                }
            </details>
            <div class="mb-3 wide">
                <label class="check-card check-inline">
                    <input asp-for="IsActive" />
                    <span>Aktif kullanıcı</span>
                </label>
            </div>
        </div>
        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-action="Index">Vazgeç</a>
            <button class="btn btn-primary" type="submit">Kaydet</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
