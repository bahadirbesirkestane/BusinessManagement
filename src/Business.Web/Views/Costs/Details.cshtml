@model Project
@{
    ViewData["Title"] = "Maliyet Detayı";
    var summary = CostSummaryBuilder.Build(Model);
    var canManageCosts = User.HasClaim(AppClaimTypes.Permission, AppPermissions.CostsManage) || User.IsInRole(AppRoles.Admin);
    var canViewBudget = User.IsInRole(AppRoles.Admin) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectBudgetView) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectBudgetManage);
    var canManageBudget = User.IsInRole(AppRoles.Admin) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectBudgetManage);
}

<section class="project-header">
    <div>
        <p class="section-kicker">@Model.Code</p>
        <h2>@Model.Name - maliyet detayı</h2>
        <p>@(Model.Customer?.Name ?? Model.CustomerName ?? "Müşteri yok")</p>
    </div>
    <div class="project-header-actions">
        @if (summary.GrandTotalInProjectCurrency.HasValue)
        {
            <span class="status-pill">@summary.GrandTotalInProjectCurrency.Value.ToString("N2") @summary.ProjectCurrency</span>
        }
        else
        {
            <span class="status-pill">Kur bilgisi bekleniyor</span>
        }
        <a class="btn btn-outline-success btn-sm" asp-action="ExportDetails" asp-route-id="@Model.Id">Excel indir</a>
        @if (canManageCosts)
        {
            <a class="btn btn-primary btn-sm" asp-action="Create" asp-route-projectId="@Model.Id">Maliyet kalemi ekle</a>
        }
    </div>
</section>

<div class="dashboard-grid">
    <section class="panel-block">
        <div class="panel-heading">
            <div>
                <p class="section-kicker">Özet</p>
                <h2>Toplamlar</h2>
            </div>
        </div>
        <dl class="row mb-0">
            @if (canViewBudget)
            {
                <dt class="col-sm-5">Proje bütçesi</dt>
                <dd class="col-sm-7">@(summary.Budget?.ToString("N2") ?? "-") @summary.ProjectCurrency</dd>
            }

            <dt class="col-sm-5">Elle girilen maliyetler</dt>
            <dd class="col-sm-7">
                @foreach (var total in summary.CostItemTotals)
                {
                    <div>@total.Amount.ToString("N2") @total.Currency</div>
                }
            </dd>

            <dt class="col-sm-5">Projeye bağlı siparişler</dt>
            <dd class="col-sm-7">
                @foreach (var total in summary.PurchaseOrderTotals)
                {
                    <div>@total.Amount.ToString("N2") @total.Currency</div>
                }
            </dd>

            <dt class="col-sm-5">Toplam maliyet</dt>
            <dd class="col-sm-7">
                @foreach (var total in summary.CombinedTotals)
                {
                    <div>@total.Amount.ToString("N2") @total.Currency</div>
                }
            </dd>

            <dt class="col-sm-5">EUR/TRY kuru</dt>
            <dd class="col-sm-7">@(summary.EurToTryRate?.ToString("N4") ?? "-")</dd>

            <dt class="col-sm-5">USD/TRY kuru</dt>
            <dd class="col-sm-7">@(summary.UsdToTryRate?.ToString("N4") ?? "-")</dd>

            @if (summary.GrandTotalInProjectCurrency.HasValue)
            {
                <dt class="col-sm-5">Dönüştürülmüş toplam</dt>
                <dd class="col-sm-7"><strong>@summary.GrandTotalInProjectCurrency.Value.ToString("N2") @summary.ProjectCurrency</strong></dd>
            }

            @if (canViewBudget && summary.RemainingBudgetInProjectCurrency.HasValue)
            {
                <dt class="col-sm-5">Bütçe farkı</dt>
                <dd class="col-sm-7"><strong>@summary.RemainingBudgetInProjectCurrency.Value.ToString("N2") @summary.ProjectCurrency</strong></dd>
            }
        </dl>

        @if (summary.HasMissingExchangeRates)
        {
            <div class="alert alert-warning mt-3 mb-0">
                Dönüştürülmüş toplam hesaplanamadı. Eksik kur: @string.Join(", ", summary.MissingRateCurrencies)
            </div>
        }
    </section>

    <section class="panel-block">
        <div class="panel-heading">
            <div>
                <p class="section-kicker">Bütçe</p>
                <h2>Bütçe ve kur yönetimi</h2>
            </div>
        </div>
        @if (canManageBudget)
        {
            <form asp-action="UpdateBudgetSettings" method="post" class="app-form">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="form-grid">
                    <div class="mb-3">
                        <label class="form-label" for="budget">Bütçe</label>
                        <input id="budget" name="budget" type="text" inputmode="decimal" value="@Model.Budget?.ToString()" class="form-control" placeholder="150000 veya 150000,50" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="currency">Para birimi</label>
                        <select id="currency" name="currency" class="form-select">
                            @foreach (var currencyItem in CurrencyMetadata.GetSelectList())
                            {
                                <option value="@currencyItem.Value" selected="@(Model.Currency == currencyItem.Value)">@currencyItem.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="eurToTryRate">EUR/TRY</label>
                        <input id="eurToTryRate" name="eurToTryRate" type="text" inputmode="decimal" value="@Model.EurToTryRate?.ToString()" class="form-control" placeholder="43,25 veya 43.25" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="usdToTryRate">USD/TRY</label>
                        <input id="usdToTryRate" name="usdToTryRate" type="text" inputmode="decimal" value="@Model.UsdToTryRate?.ToString()" class="form-control" placeholder="39,80 veya 39.80" />
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn btn-primary btn-sm" type="submit">Bütçe ve kurları güncelle</button>
                </div>
            </form>
        }
        else
        {
            <p class="text-muted mb-0">Bütçe ve kur bilgilerini güncellemek için ayrı bütçe yönetim yetkisi gerekir.</p>
        }
    </section>
</div>

<section class="panel-block mt-3">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Sipariş</p>
            <h2>Projeye bağlı siparişler</h2>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead><tr><th>Sipariş</th><th>Tedarikçi</th><th>Durum</th><th>Tutar</th><th></th></tr></thead>
            <tbody>
            @foreach (var order in Model.PurchaseOrders)
            {
                var amount = CostSummaryBuilder.GetOrderAmount(order);
                <tr>
                    <td><strong>@order.OrderNumber</strong><small class="d-block text-muted">@order.Content</small></td>
                    <td>@(order.Supplier?.Name ?? "-")</td>
                    <td><span class="status-pill status-@order.Status.ToString().ToLowerInvariant()">@order.Status.ToDisplayName()</span></td>
                    <td>@amount.ToString("N2") @order.Currency</td>
                    <td class="text-end"><a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@order.Id">Sipariş</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

<section class="panel-block mt-3">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Maliyet</p>
            <h2>Maliyet kalemleri</h2>
        </div>
    </div>
    @if (canManageCosts)
    {
        <form id="bulkDeleteForm" asp-action="BulkDelete" method="post" class="bulk-action-bar">
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <button class="btn btn-outline-danger btn-sm" type="submit">Seçilenleri sil</button>
        </form>
    }
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead><tr><th>Tarih</th><th>Tür</th><th>Açıklama</th><th>Bağlı sipariş</th><th>Tutar</th><th>Not</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model.CostItems)
            {
                <tr>
                    <td>
                        @if (canManageCosts)
                        {
                            <input type="checkbox" name="ids" value="@item.Id" form="bulkDeleteForm" />
                        }
                    </td>
                    <td>@(item.CostDate?.ToString("dd.MM.yyyy") ?? item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy"))</td>
                    <td>@item.Type.ToDisplayName()</td>
                    <td><strong>@item.Description</strong></td>
                    <td>@(item.PurchaseOrder?.OrderNumber ?? "-")</td>
                    <td>@item.Amount.ToString("N2") @item.Currency</td>
                    <td>@(item.Notes ?? "-")</td>
                    <td class="text-end">
                        @if (canManageCosts)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button class="btn btn-link btn-sm text-danger p-0 ms-2" type="submit">Sil</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
