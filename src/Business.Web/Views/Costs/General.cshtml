@model IReadOnlyList<ProjectCostItem>
@{
    ViewData["Title"] = "Genel Giderler";
    var totals = CostSummaryBuilder.GroupByCurrency(Model.Select(x => (CurrencyMetadata.NormalizeStored(x.Currency), x.Amount)));
    var canManageCosts = User.HasClaim(AppClaimTypes.Permission, AppPermissions.CostsManage) || User.IsInRole(AppRoles.Admin);
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Maliyet</p>
            <h2>Genel giderler</h2>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-success btn-sm"
               asp-action="ExportGeneral"
               asp-route-q="@ViewBag.FilterQ"
               asp-route-projectId="@ViewBag.FilterProjectId"
               asp-route-currency="@ViewBag.FilterCurrency">Excel indir</a>
            @foreach (var total in totals)
            {
                <span class="status-pill">@total.Amount.ToString("N2") @total.Currency</span>
            }
        </div>
    </div>
    <form method="get" class="diagram-filter-bar mb-3">
        <input type="text" name="q" value="@ViewBag.FilterQ" class="form-control form-control-sm" placeholder="Açıklama veya proje ara" />
        <select name="projectId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Proje ara veya seç">
            <option value="">Tüm projeler</option>
            @foreach (var project in ViewBag.Projects)
            {
                <option value="@project.Id" selected="@(ViewBag.FilterProjectId == project.Id)">@project.Code - @project.Name</option>
            }
        </select>
        <select name="currency" class="form-select form-select-sm">
            <option value="">Tüm para birimleri</option>
            @foreach (var currencyItem in CurrencyMetadata.GetSelectList())
            {
                <option value="@currencyItem.Value" selected="@(ViewBag.FilterCurrency == currencyItem.Value)">@currencyItem.Text</option>
            }
        </select>
        <button class="btn btn-outline-primary btn-sm" type="submit">Filtrele</button>
        <a class="btn btn-outline-secondary btn-sm" asp-action="General">Temizle</a>
    </form>
    @if (canManageCosts)
    {
        <form id="bulkDeleteForm" asp-action="BulkDelete" method="post" class="bulk-action-bar smart-bulk-bar" data-bulk-panel="bulkDeleteForm" hidden>
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <span class="bulk-selection-count" data-bulk-count="bulkDeleteForm">0 kayıt seçildi</span>
            <div class="bulk-bar-actions">
                <button class="btn btn-outline-secondary btn-sm" type="button" data-bulk-clear="bulkDeleteForm">Seçimi temizle</button>
                <button class="btn btn-outline-danger btn-sm" type="submit" data-bulk-submit="bulkDeleteForm">Seçilenleri sil</button>
            </div>
        </form>
    }
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    @if (canManageCosts)
                    {
                        <th class="bulk-check-cell">
                            <input type="checkbox" data-bulk-toggle="bulkDeleteForm" aria-label="Tüm genel giderleri seç" />
                        </th>
                    }
                    <th>Tarih</th>
                    <th>Proje</th>
                    <th>Tür</th>
                    <th>Açıklama</th>
                    <th>Tutar</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    @if (canManageCosts)
                    {
                        <td>
                            <input type="checkbox" name="ids" value="@item.Id" form="bulkDeleteForm" />
                        </td>
                    }
                    <td>@(item.CostDate?.ToString("dd.MM.yyyy") ?? item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy"))</td>
                    <td>@(item.Project?.Code ?? "Genel")</td>
                    <td>@item.Type.ToDisplayName()</td>
                    <td>@item.Description</td>
                    <td>@item.Amount.ToString("N2") @item.Currency</td>
                    <td class="text-end">
                        @if (item.ProjectId.HasValue)
                        {
                            <a asp-action="Details" asp-route-id="@item.ProjectId">Proje maliyeti</a>
                        }
                        else
                        {
                            <span class="text-muted">Genel gider</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
