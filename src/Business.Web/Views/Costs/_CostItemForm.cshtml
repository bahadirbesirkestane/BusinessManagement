@model ProjectCostItem

<section class="panel-block form-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Maliyet</p>
            <h2>@ViewData["Title"]</h2>
        </div>
    </div>
    <form method="post" class="app-form">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div class="mb-3">
                <label asp-for="ProjectId" class="form-label">Proje</label>
                <select asp-for="ProjectId" class="form-select" data-searchable-select data-search-placeholder="Proje ara veya seç">
                    <option value="">Genel gider</option>
                    @foreach (var project in ViewBag.Projects)
                    {
                        <option value="@project.Id">@project.Code - @project.Name</option>
                    }
                </select>
                <span asp-validation-for="ProjectId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="PurchaseOrderId" class="form-label">BaÄŸlÄ± sipariÅŸ</label>
                <select asp-for="PurchaseOrderId" class="form-select">
                    <option value="">Yok</option>
                    @foreach (var order in ViewBag.PurchaseOrders)
                    {
                        <option value="@order.Id">@order.OrderNumber - @order.Content</option>
                    }
                </select>
            </div>
            <div class="mb-3"><label asp-for="Type" class="form-label">TÃ¼r</label><select asp-for="Type" asp-items="Html.GetEnumSelectList<CostItemType>()" class="form-select"></select></div>
            @if (User.IsInRole(AppRoles.Admin))
            {
                <div class="mb-3"><label asp-for="Visibility" class="form-label">Görünürlük</label><select asp-for="Visibility" asp-items="Html.GetEnumSelectList<RecordVisibility>()" class="form-select"></select></div>
            }
            <div class="mb-3 wide"><label asp-for="Description" class="form-label">Açıklama</label><input asp-for="Description" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Amount" class="form-label">Tutar</label><input asp-for="Amount" type="number" step="0.01" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Currency" class="form-label">Para birimi</label><input asp-for="Currency" class="form-control" /></div>
            <div class="mb-3"><label asp-for="CostDate" class="form-label">Tarih</label><input asp-for="CostDate" type="date" class="form-control" /></div>
            <div class="mb-3 wide"><label asp-for="Notes" class="form-label">Not</label><textarea asp-for="Notes" rows="3" class="form-control"></textarea></div>
        </div>
        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-action="Projects">Vazgeç</a>
            <button class="btn btn-primary" type="submit">Kaydet</button>
        </div>
    </form>
</section>
