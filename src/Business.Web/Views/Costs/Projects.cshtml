@model IReadOnlyList<Project>
@{
    ViewData["Title"] = "Proje Maliyetleri";
    var canViewBudget = User.IsInRole(AppRoles.Admin) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectBudgetView) || User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectBudgetManage);
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Maliyet</p>
            <h2>Proje maliyetleri</h2>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-success btn-sm"
               asp-action="ExportProjects"
               asp-route-q="@ViewBag.FilterQ"
               asp-route-customerId="@ViewBag.FilterCustomerId"
               asp-route-currency="@ViewBag.FilterCurrency">Excel indir</a>
            @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.CostsManage) || User.IsInRole(AppRoles.Admin))
            {
                <a class="btn btn-primary btn-sm" asp-action="Create">Maliyet kalemi ekle</a>
            }
        </div>
    </div>
    <form method="get" class="diagram-filter-bar mb-3">
        <input type="text" name="q" value="@ViewBag.FilterQ" class="form-control form-control-sm" placeholder="Kod, proje, müşteri ara" />
        <select name="customerId" class="form-select form-select-sm" data-searchable-select data-search-placeholder="Müşteri ara veya seç">
            <option value="">Tüm müşteriler</option>
            @foreach (var customer in ViewBag.Customers)
            {
                <option value="@customer.Id" selected="@(ViewBag.FilterCustomerId == customer.Id)">@customer.Name</option>
            }
        </select>
        <select name="currency" class="form-select form-select-sm">
            <option value="">Tüm para birimleri</option>
            @foreach (var currencyItem in CurrencyMetadata.GetSelectList())
            {
                <option value="@currencyItem.Value" selected="@(ViewBag.FilterCurrency == currencyItem.Value)">@currencyItem.Text</option>
            }
        </select>
        <button class="btn btn-outline-primary btn-sm" type="submit">Filtrele</button>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Projects">Temizle</a>
    </form>
    <div class="table-responsive">
        <table class="table app-table align-middle">
            <thead>
                <tr>
                    <th>Kod</th>
                    <th>Proje</th>
                    <th>Müşteri</th>
                    @if (canViewBudget)
                    {
                        <th>Bütçe</th>
                    }
                    <th>Maliyet Kalemleri</th>
                    <th>Sipariş Tutarı</th>
                    <th>Toplam</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var project in Model)
            {
                var summary = CostSummaryBuilder.Build(project);
                <tr>
                    <td><strong>@project.Code</strong></td>
                    <td>@project.Name</td>
                    <td>@(project.Customer?.Name ?? project.CustomerName ?? "-")</td>
                    @if (canViewBudget)
                    {
                        <td>@(project.Budget?.ToString("N2") ?? "-") @summary.ProjectCurrency</td>
                    }
                    <td>
                        @foreach (var total in summary.CostItemTotals)
                        {
                            <div>@total.Amount.ToString("#,##0.####") @total.Currency</div>
                        }
                    </td>
                    <td>
                        @foreach (var total in summary.PurchaseOrderTotals)
                        {
                            <div>@total.Amount.ToString("#,##0.####") @total.Currency</div>
                        }
                    </td>
                    <td>
                        @if (summary.GrandTotalInProjectCurrency.HasValue)
                        {
                            <strong class="d-block">@summary.GrandTotalInProjectCurrency.Value.ToString("#,##0.####") @summary.ProjectCurrency</strong>
                        }
                        @foreach (var total in summary.CombinedTotals)
                        {
                            <div class="text-muted">@total.Amount.ToString("#,##0.####") @total.Currency</div>
                        }
                        @if (summary.HasMissingExchangeRates)
                        {
                            <small class="text-warning d-block">Kur eksiği: @string.Join(", ", summary.MissingRateCurrencies)</small>
                        }
                    </td>
                    <td class="text-end"><a asp-action="Details" asp-route-id="@project.Id">Maliyet detayı</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
