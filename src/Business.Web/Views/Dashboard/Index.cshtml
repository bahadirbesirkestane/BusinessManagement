@model Business.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Yönetim Paneli";
    var canCreateTask = User.IsInRole(AppRoles.Admin) ||
        User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksCreate) ||
        User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksManage) ||
        User.HasClaim(AppClaimTypes.Permission, AppPermissions.ProjectsManage);
    var canViewReviewQueue = User.IsInRole(AppRoles.Admin) ||
        User.HasClaim(AppClaimTypes.Permission, AppPermissions.TasksComplete);
}

<div class="metric-grid metric-grid-three">
    <div class="metric-card">
        <span>Aktif proje</span>
        <strong>@Model.ActiveProjectCount</strong>
        <small>Planlanan, devam eden ve bekleyen işler</small>
    </div>
    <div class="metric-card">
        <span>Açık sipariş</span>
        <strong>@Model.OpenOrderCount</strong>
        <small>Teslim veya iptal edilmemiş kalemler</small>
    </div>
    <div class="metric-card">
        <span>Malzeme talebi</span>
        <strong>@Model.PendingMaterialRequestCount</strong>
        <small>Bekleyen ihtiyaçlar</small>
    </div>
</div>

<section class="welcome-panel dashboard-focus-panel">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Görev özeti</p>
            <h2>@Model.MyTaskBannerTitle</h2>
            <p class="dashboard-focus-copy">@Model.MyTaskBannerMessage</p>
        </div>
        <div class="dashboard-focus-toolbar">
            <div class="dashboard-focus-actions">
                <a class="btn btn-primary btn-sm" asp-action="Workspace">İşlerim</a>
                <a class="btn btn-outline-secondary btn-sm" asp-controller="ProjectTasks" asp-action="AssignedToMe">Bana atananlar</a>
                @if (canCreateTask)
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="ProjectTasks" asp-action="Create" asp-route-returnUrl="@Context.Request.Path">Görev ekle</a>
                }
                @if (canViewReviewQueue)
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-action="ReviewQueue">Kontrol listesi</a>
                }
            </div>
            <div class="dashboard-stats-strip">
                <div class="dashboard-stat-chip">
                    <strong>@Model.MyOpenTaskCount</strong>
                    <span>Açık görev</span>
                </div>
                <div class="dashboard-stat-chip">
                    <strong>@Model.MyOverdueTaskCount</strong>
                    <span>Geciken</span>
                </div>
                <div class="dashboard-stat-chip">
                    <strong>@Model.MyDueSoonTaskCount</strong>
                    <span>Yaklaşan</span>
                </div>
            </div>
        </div>
    </div>

    <div class="dashboard-focus-content">
        <div class="dashboard-task-list-block">
            <p class="section-kicker">Görev listesi</p>
            <div class="list-stack">
                @if (!Model.MyTasks.Any())
                {
                    <p class="empty-note">Size atanmış veya sorumlu olduğunuz açık görev görünmüyor.</p>
                }
                else
                {
                    @foreach (var task in Model.MyTasks)
                    {
                        <a class="list-row list-row-link dashboard-task-row" asp-controller="ProjectTasks" asp-action="Details" asp-route-id="@task.Id" asp-route-returnUrl="@Context.Request.Path">
                            <span class="dashboard-task-main">
                                <strong>@task.Title</strong>
                                <small>@task.Context · @task.RoleText</small>
                            </span>
                            <span class="dashboard-task-meta">
                                <span class="priority-pill priority-@task.PriorityCss">@task.PriorityText</span>
                                <span class="status-pill status-@task.StatusCss">@task.StatusText</span>
                                <small class="@(task.IsOverdue ? "text-danger" : string.Empty)">@(task.DueDate?.ToString("dd.MM.yyyy") ?? "Termin yok")</small>
                            </span>
                        </a>
                    }
                }
            </div>
        </div>
    </div>
</section>

<section class="panel-block dashboard-project-flow">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Proje akışı</p>
            <h2>Son projeler</h2>
        </div>
        <a asp-controller="Projects" asp-action="Index">Tümünü gör</a>
    </div>
    <div class="list-stack">
        @foreach (var project in Model.RecentProjects)
        {
            <a class="list-row" asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id">
                <span>
                    <strong>@project.Code</strong>
                    <small>@project.Name</small>
                </span>
                <span class="status-pill">@project.Status.ToDisplayName()</span>
            </a>
        }
    </div>
</section>

<div class="dashboard-grid dashboard-grid-secondary">
    @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.PurchasingView))
    {
        <section class="panel-block">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Satın alma</p>
                    <h2>Son siparişler</h2>
                </div>
                <a asp-controller="PurchaseOrders" asp-action="Index">Liste</a>
            </div>
            <div class="list-stack">
                @foreach (var order in Model.RecentOrders)
                {
                    <div class="list-row">
                        <span>
                            <strong>@order.Content</strong>
                            <small>@(order.Project?.Code ?? "Genel") · @(order.Supplier?.Name ?? "Tedarikçi yok")</small>
                        </span>
                        <span class="status-pill">@order.Status.ToDisplayName()</span>
                    </div>
                }
            </div>
        </section>
    }

    @if (User.HasClaim(AppClaimTypes.Permission, AppPermissions.MaterialRequestsView))
    {
        <section class="panel-block">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Atölye</p>
                    <h2>Malzeme ihtiyaçları</h2>
                </div>
                <a asp-controller="MaterialRequests" asp-action="Create">Yeni talep</a>
            </div>
            <div class="list-stack">
                @foreach (var request in Model.MaterialRequests)
                {
                    <div class="list-row">
                        <span>
                            <strong>@request.RequestedItem</strong>
                            <small>@(request.Project?.Code ?? "Genel") · @request.QuantityText</small>
                        </span>
                        <span class="status-pill">@request.Status.ToDisplayName()</span>
                    </div>
                }
            </div>
        </section>
    }
</div>
