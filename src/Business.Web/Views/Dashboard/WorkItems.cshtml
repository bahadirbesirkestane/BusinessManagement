@model IReadOnlyList<DashboardWorkItemViewModel>
@{
    var title = ViewData["Title"]?.ToString() ?? "Dashboard";
    var infoText = ViewData["InfoText"]?.ToString();
    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<section class="panel-block">
    <div class="panel-heading">
        <div>
            <p class="section-kicker">Dashboard</p>
            <h2>@title</h2>
        </div>
        <a class="btn btn-outline-primary btn-sm" asp-action="Index">Genel Bakış</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(infoText))
    {
        <div class="welcome-panel dashboard-focus-panel mb-3">
            <p class="section-kicker">Kısa bilgi</p>
            <p class="dashboard-focus-copy mb-0">@infoText</p>
        </div>
    }

    @if (!Model.Any())
    {
        <p class="empty-note">Bu başlık altında gösterilecek kayıt yok.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table app-table align-middle">
                <thead>
                    <tr>
                        <th>Modül</th>
                        <th>Kayıt</th>
                        <th>Bağlantı</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr class="status-row status-@item.StatusCss"
                        data-row-link="@Url.Action(item.Action, item.Controller, new { id = item.Id, returnUrl = currentReturnUrl })">
                        <td>@item.Module</td>
                        <td><strong>@item.Title</strong></td>
                        <td>@(item.Subtitle ?? "-")</td>
                        <td>@(item.Date?.ToString("dd.MM.yyyy") ?? "-")</td>
                        <td><span class="status-pill status-@item.StatusCss">@item.StatusText</span></td>
                        <td class="text-end">
                            <a asp-controller="@item.Controller" asp-action="@item.Action" asp-route-id="@item.Id" asp-route-returnUrl="@currentReturnUrl">Detay</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
