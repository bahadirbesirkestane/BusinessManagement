@model Invoice
@{
    var lines = Model.Lines.ToList();
}

<section class="panel-block form-panel">
    <div class="panel-heading"><div><p class="section-kicker">Gelir / gider</p><h2>@ViewData["Title"]</h2></div></div>
    <form method="post" class="app-form invoice-form" data-invoice-form>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="SubTotal" data-invoice-subtotal-input />
        <input type="hidden" asp-for="VatTotal" data-invoice-vat-input />
        <input type="hidden" asp-for="DiscountTotal" data-invoice-discount-input />
        <input type="hidden" asp-for="GrandTotal" data-invoice-grand-input />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">
            <div class="mb-3"><label asp-for="InvoiceNumber" class="form-label">Fatura no</label><input asp-for="InvoiceNumber" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Type" class="form-label">Tür</label><select asp-for="Type" asp-items="Html.GetEnumSelectList<InvoiceType>()" class="form-select"></select></div>
            <div class="mb-3"><label asp-for="Status" class="form-label">Durum</label><select asp-for="Status" asp-items="Html.GetEnumSelectList<InvoiceStatus>()" class="form-select"></select></div>
            <div class="mb-3"><label asp-for="CustomerId" class="form-label">Müşteri</label><select asp-for="CustomerId" class="form-select" data-searchable-select data-search-placeholder="Müşteri ara veya seç"><option value="">Seçilmedi</option>@foreach (var customer in ViewBag.Customers){<option value="@customer.Id">@customer.Name</option>}</select></div>
            <div class="mb-3"><label asp-for="SupplierId" class="form-label">Tedarikçi</label><select asp-for="SupplierId" class="form-select" data-searchable-select data-search-placeholder="Tedarikçi ara veya seç"><option value="">Seçilmedi</option>@foreach (var supplier in ViewBag.Suppliers){<option value="@supplier.Id">@supplier.Name</option>}</select></div>
            <div class="mb-3"><label asp-for="ProjectId" class="form-label">Proje</label><select asp-for="ProjectId" class="form-select" data-searchable-select data-search-placeholder="Proje ara veya seç"><option value="">Seçilmedi</option>@foreach (var project in ViewBag.Projects){<option value="@project.Id">@project.Code - @project.Name</option>}</select></div>
            <div class="mb-3"><label asp-for="PurchaseOrderId" class="form-label">Sipariş</label><select asp-for="PurchaseOrderId" class="form-select"><option value="">Seçilmedi</option>@foreach (var order in ViewBag.PurchaseOrders){<option value="@order.Id">@order.OrderNumber - @order.Content</option>}</select></div>
            <div class="mb-3"><label asp-for="IssueDate" class="form-label">Fatura tarihi</label><input asp-for="IssueDate" type="date" class="form-control" /></div>
            <div class="mb-3"><label asp-for="DueDate" class="form-label">Vade tarihi</label><input asp-for="DueDate" type="date" class="form-control" /></div>
            <div class="mb-3"><label asp-for="PaidAt" class="form-label">Ödeme tarihi</label><input asp-for="PaidAt" type="date" class="form-control" /></div>
            <div class="mb-3"><label asp-for="Currency" class="form-label">Para birimi</label><input asp-for="Currency" class="form-control" /></div>
            <div class="mb-3"><label asp-for="PaymentTerm" class="form-label">Vade açıklaması</label><input asp-for="PaymentTerm" class="form-control" /></div>
            <div class="mb-3 wide"><label asp-for="Notes" class="form-label">Not</label><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div>
        </div>

        <div class="quick-order-sheet-wrap">
            <table class="quick-order-sheet invoice-line-sheet">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Açıklama</th>
                        <th>Malzeme</th>
                        <th>Miktar</th>
                        <th>Birim</th>
                        <th>Birim fiyat</th>
                        <th>KDV %</th>
                        <th>İskonto</th>
                        <th>Toplam</th>
                        <th>Not</th>
                    </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < lines.Count; i++)
                {
                    var line = lines[i];
                    var disabled = i > 0 && string.IsNullOrWhiteSpace(line.Description);
                    <tr class="quick-order-row @(disabled ? "is-disabled" : "")" data-row-index="@i">
                        <td class="row-number">@(i + 1)</td>
                        <td><input name="Lines[@i].Description" value="@line.Description" class="form-control form-control-sm quick-cell main-cell" disabled="@disabled" autocomplete="off" /></td>
                        <td>
                            <select name="Lines[@i].MaterialId" class="form-select form-select-sm quick-cell" disabled="@disabled">
                                <option value="">Seçilmedi</option>
                                @foreach (var material in ViewBag.Materials)
                                {
                                    <option value="@material.Id" selected="@(line.MaterialId == material.Id)">@material.Name</option>
                                }
                            </select>
                        </td>
                        <td><input name="Lines[@i].Quantity" value="@line.Quantity.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)" type="number" step="0.0001" class="form-control form-control-sm quick-cell quantity-cell" disabled="@disabled" /></td>
                        <td><input name="Lines[@i].Unit" value="@line.Unit" class="form-control form-control-sm quick-cell" disabled="@disabled" /></td>
                        <td><input name="Lines[@i].UnitPrice" value="@line.UnitPrice.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)" type="number" step="0.0001" class="form-control form-control-sm quick-cell unit-price-cell" disabled="@disabled" /></td>
                        <td><input name="Lines[@i].VatRate" value="@line.VatRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" type="number" step="0.01" class="form-control form-control-sm quick-cell vat-rate-cell" disabled="@disabled" /></td>
                        <td><input name="Lines[@i].DiscountAmount" value="@line.DiscountAmount.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)" type="number" step="0.0001" class="form-control form-control-sm quick-cell discount-cell" disabled="@disabled" /></td>
                        <td><input name="Lines[@i].LineTotal" value="@line.LineTotal.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)" type="number" step="0.0001" class="form-control form-control-sm quick-cell total-cell" disabled="@disabled" readonly /></td>
                        <td><input name="Lines[@i].Notes" value="@line.Notes" class="form-control form-control-sm quick-cell" disabled="@disabled" /></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="amount-breakdown invoice-total-preview">
            <div><span>Ara toplam</span><strong><span data-invoice-subtotal>0</span> <span data-invoice-currency>@Model.Currency</span></strong></div>
            <div><span>KDV</span><strong><span data-invoice-vat>0</span> <span data-invoice-currency>@Model.Currency</span></strong></div>
            <div><span>İskonto</span><strong><span data-invoice-discount>0</span> <span data-invoice-currency>@Model.Currency</span></strong></div>
            <div class="grand"><span>Genel toplam</span><strong><span data-invoice-grand>0</span> <span data-invoice-currency>@Model.Currency</span></strong></div>
        </div>

        <div class="form-actions"><a class="btn btn-outline-secondary" asp-action="Index">Vazgeç</a><button class="btn btn-primary" type="submit">Kaydet</button></div>
    </form>
</section>

<script>
    (() => {
        const form = document.querySelector('[data-invoice-form]');
        if (!form) return;

        const tbody = form.querySelector('tbody');
        const currencyInput = form.querySelector('[name="Currency"]');
        const subtotalInput = form.querySelector('[data-invoice-subtotal-input]');
        const vatInput = form.querySelector('[data-invoice-vat-input]');
        const discountInput = form.querySelector('[data-invoice-discount-input]');
        const grandInput = form.querySelector('[data-invoice-grand-input]');

        const formatAmount = value => value.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 4 });
        const formatInputNumber = value => Number(value.toFixed(4)).toString();
        const numberValue = input => Number(String(input?.value || '').replace(',', '.')) || 0;

        const enableRow = row => {
            row.classList.remove('is-disabled');
            row.querySelectorAll('input, select').forEach(input => input.disabled = false);
        };

        const addRow = () => {
            const rows = [...tbody.querySelectorAll('tr')];
            const last = rows[rows.length - 1];
            const nextIndex = rows.length;
            const row = last.cloneNode(true);
            row.dataset.rowIndex = nextIndex;
            row.classList.add('is-disabled');
            row.querySelector('.row-number').textContent = nextIndex + 1;
            row.querySelectorAll('input, select').forEach(input => {
                input.name = input.name.replace(/Lines\[\d+\]/, `Lines[${nextIndex}]`);
                if (input.tagName === 'SELECT') input.selectedIndex = 0;
                else input.value = input.classList.contains('quantity-cell') ? '1' : input.classList.contains('vat-rate-cell') ? '20' : '';
                input.disabled = true;
            });
            tbody.appendChild(row);
            return row;
        };

        const activateNextRow = row => {
            let next = row.nextElementSibling;
            if (!next) next = addRow();
            enableRow(next);
            next.querySelector('.main-cell')?.focus();
        };

        const calculateRow = row => {
            const quantity = numberValue(row.querySelector('.quantity-cell'));
            const unitPrice = numberValue(row.querySelector('.unit-price-cell'));
            const vatRate = numberValue(row.querySelector('.vat-rate-cell'));
            const discount = numberValue(row.querySelector('.discount-cell'));
            const subtotal = quantity * unitPrice;
            const total = subtotal + (subtotal * vatRate / 100) - discount;
            const totalInput = row.querySelector('.total-cell');
            if (totalInput) totalInput.value = total > 0 ? formatInputNumber(total) : '0';
            return { subtotal, vat: subtotal * vatRate / 100, discount, total };
        };

        const updateTotals = () => {
            let subtotal = 0;
            let vat = 0;
            let discount = 0;
            let grand = 0;

            tbody.querySelectorAll('tr:not(.is-disabled)').forEach(row => {
                if (!row.querySelector('.main-cell')?.value.trim()) return;
                const rowTotals = calculateRow(row);
                subtotal += rowTotals.subtotal;
                vat += rowTotals.vat;
                discount += rowTotals.discount;
                grand += rowTotals.total;
            });

            subtotalInput.value = formatInputNumber(subtotal);
            vatInput.value = formatInputNumber(vat);
            discountInput.value = formatInputNumber(discount);
            grandInput.value = formatInputNumber(grand);
            form.querySelector('[data-invoice-subtotal]').textContent = formatAmount(subtotal);
            form.querySelector('[data-invoice-vat]').textContent = formatAmount(vat);
            form.querySelector('[data-invoice-discount]').textContent = formatAmount(discount);
            form.querySelector('[data-invoice-grand]').textContent = formatAmount(grand);
            form.querySelectorAll('[data-invoice-currency]').forEach(x => x.textContent = currencyInput?.value || 'TRY');
        };

        form.addEventListener('keydown', event => {
            if (event.key !== 'Enter') return;
            const cell = event.target.closest('.quick-cell');
            if (!cell) return;

            event.preventDefault();
            const row = event.target.closest('tr');
            if (event.target.classList.contains('main-cell') && event.target.value.trim()) {
                activateNextRow(row);
                updateTotals();
                return;
            }

            const enabledCells = [...row.querySelectorAll('.quick-cell:not(:disabled):not([readonly])')];
            const index = enabledCells.indexOf(event.target);
            const nextCell = enabledCells[index + 1];
            if (nextCell) nextCell.focus();
            else activateNextRow(row);
        });

        form.addEventListener('input', updateTotals);
        form.addEventListener('submit', () => {
            form.querySelectorAll('tr.is-disabled input, tr.is-disabled select').forEach(input => input.disabled = false);
            updateTotals();
        });

        updateTotals();
    })();
</script>
